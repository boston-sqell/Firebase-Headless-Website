# -- Firebase Admin (server-side only -- never sent to the browser) ---------
# Get these from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key.
# In production on Cloud Run you can omit all three and rely on the
# service's runtime service account (Application Default Credentials)
# instead -- see README "Deploying" section. Recommended for production.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# Firebase Storage bucket for admin-uploaded images. Defaults to
# "<project-id>.appspot.com" if unset -- check Project Settings -> Storage in
# the Firebase Console for your actual bucket name (newer projects may use
# a "<project-id>.firebasestorage.app" bucket instead).
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# -- Firebase client config (admin login page only) --------------------------
# Get these from Firebase Console -> Project Settings -> General -> Your apps
# -> Web app -> SDK setup and configuration. These are NOT secret (see
# src/lib/firebase-client.ts for why) but must be set for /admin/login to work.
PUBLIC_FIREBASE_API_KEY=your-web-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# -- Site config --------------------------------------------------------------
PUBLIC_SITE_URL=http://localhost:4322

# -- Optional ------------------------------------------------------------------
# FIREBASE_PREVIEW_URL=https://sosun-fihaara--preview-xxxx.web.app

# -- Wix (seeder only -- not used by the live site) ---------------------------
# WIX_CLIENT_ID=
# WIX_CLIENT_SECRET=
