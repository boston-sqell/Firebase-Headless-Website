---
import type { Promotion } from '../../lib/cms';

interface Props {
  promotion?: Promotion;
  action: string;
  error?: string;
}

const { promotion, action, error } = Astro.props;
---

<form method="post" action={action} class="admin-form">
  <input type="hidden" name="csrf_token" value={Astro.locals.csrfToken} />
  {error && <div class="admin-alert admin-alert--error">{error}</div>}

  <div class="form-row">
    <div class="field">
      <label for="title">Title *</label>
      <input type="text" id="title" name="title" required value={promotion?.title} placeholder="e.g. Fresh Dairy Range" />
    </div>
    <div class="field">
      <label for="label">Label Tag</label>
      <input type="text" id="label" name="label" value={promotion?.label} placeholder="e.g. Weekly Special" />
    </div>
  </div>

  <div class="field">
    <label for="subtitle">Subtitle</label>
    <input type="text" id="subtitle" name="subtitle" value={promotion?.subtitle} placeholder="e.g. Quality dairy delivered island-wide" />
  </div>

  <div class="form-row">
    <div class="field">
      <label for="background">Background (CSS String)</label>
      <input type="text" id="background" name="background" value={promotion?.background || 'linear-gradient(135deg, #2d5a27, #4a8c40)'} placeholder="e.g. linear-gradient(...)" />
    </div>
    <div class="field">
      <label for="order">Sort Order</label>
      <input type="number" id="order" name="order" value={promotion?.order ?? 0} />
    </div>
  </div>

  <div class="field checkbox-field">
    <input type="checkbox" id="active" name="active" checked={promotion ? promotion.active : true} />
    <label for="active">Active (Visible on site)</label>
  </div>

  <button type="submit" class="btn-admin">{promotion ? 'Save Changes' : 'Create Promotion'}</button>
  <a href="/admin/promotions" class="btn-admin btn-admin--ghost">Cancel</a>
</form>
