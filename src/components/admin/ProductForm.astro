---
import type { Product, Brand, Category } from '../../lib/cms';
import ImageUpload from './ImageUpload.astro';

interface Props {
  product?: Product;
  brands: Brand[];
  categories: Category[];
  action: string;
  error?: string;
}

const { product, brands, categories, action, error } = Astro.props;
---

<form method="post" action={action} enctype="multipart/form-data" class="admin-form">
  <input type="hidden" name="csrf_token" value={Astro.locals.csrfToken} />
  {error && <div class="admin-alert admin-alert--error">{error}</div>}

  {product?.image && <input type="hidden" name="currentImage" value={product.image} />}

  <ImageUpload 
    id="image" 
    name="image" 
    label={product ? 'Replace image (JPEG, PNG, WebP, SVG)' : 'Product image (JPEG, PNG, WebP, SVG)'} 
    currentImage={product?.image} 
  />

  <div class="form-row">
    <div class="field">
      <label for="name">Product name *</label>
      <input type="text" id="name" name="name" required value={product?.name} />
    </div>
    <div class="field">
      <label for="code">Product code *</label>
      <input type="text" id="code" name="code" required value={product?.code} />
    </div>
  </div>

  <div class="form-row">
    <div class="field">
      <label for="brandName">Brand name *</label>
      <select id="brandName" name="brandName" required>
        <option value="">Select a brand...</option>
        {brands.map(b => <option value={b.name} data-slug={b.slug} selected={product?.brandName === b.name}>{b.name}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="brandSlug">Brand slug</label>
      <input type="text" id="brandSlug" name="brandSlug" value={product?.brandSlug} placeholder="e.g. pascual" />
      <p class="hint">Automatically populated when a brand is selected, but can be manually edited if needed. Must match the brand's slug.</p>
    </div>
  </div>

  <div class="form-row">
    <div class="field">
      <label for="category">Category *</label>
      <select id="category" name="category" required>
        <option value="">Select a category...</option>
        {categories.map(c => <option value={c.name} selected={product?.category === c.name}>{c.name}</option>)}
      </select>
    </div>
    <div class="field">
      <label for="subcategory">Subcategory</label>
      <input type="text" id="subcategory" name="subcategory" value={product?.subcategory} />
    </div>
  </div>

  <div class="form-row">
    <div class="field">
      <label for="price">Price (MVR)</label>
      <input type="text" id="price" name="price" value={product?.price} placeholder="Leave blank for 'Request price'" />
    </div>
    <div class="field">
      <label for="packSize">Pack size</label>
      <input type="text" id="packSize" name="packSize" value={product?.packSize} placeholder="e.g. 500g" />
    </div>
  </div>

  <div class="field">
    <label for="keywords">Search keywords</label>
    <input type="text" id="keywords" name="keywords" value={product?.keywords} placeholder="comma separated, helps search" />
  </div>

  <div class="field checkbox-row">
    <input type="checkbox" id="active" name="active" checked={product?.active !== false} />
    <label for="active" style="margin:0">Visible on the public site</label>
  </div>

  <button type="submit" class="btn-admin">{product ? 'Save Changes' : 'Create Product'}</button>
  <a href="/admin/products" class="btn-admin btn-admin--ghost">Cancel</a>
</form>

<script>
  const brandSelect = document.getElementById('brandName') as HTMLSelectElement;
  const brandSlugInput = document.getElementById('brandSlug') as HTMLInputElement;

  if (brandSelect && brandSlugInput) {
    brandSelect.addEventListener('change', () => {
      const selectedOption = brandSelect.options[brandSelect.selectedIndex];
      if (selectedOption && selectedOption.dataset.slug) {
        brandSlugInput.value = selectedOption.dataset.slug;
      }
    });
  }
</script>
