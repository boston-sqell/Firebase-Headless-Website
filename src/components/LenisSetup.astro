---
// LenisSetup.astro
---

<script>
  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const precisePointer = window.matchMedia('(pointer: fine)').matches;

  // Native scrolling is more predictable for touch and reduced-motion users.
  const lenis = new Lenis({
    autoRaf: !reduceMotion && precisePointer,
    lerp: 0.1,
    wheelMultiplier: 1,
    smoothWheel: !reduceMotion && precisePointer,
  });

  // Sync Lenis with GSAP ScrollTrigger
  lenis.on('scroll', ScrollTrigger.update);

  if (!reduceMotion && precisePointer) {
    gsap.ticker.add((time) => lenis.raf(time * 1000));
  }

  gsap.ticker.lagSmoothing(0);

  // Handle Astro view transitions (re-initialize on swap)
  document.addEventListener('astro:page-load', () => {
    ScrollTrigger.refresh();
  });
</script>
