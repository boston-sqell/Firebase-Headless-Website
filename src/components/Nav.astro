<header class="site-header">
  <div class="container">
    <nav class="nav" aria-label="Primary">
      <a class="nav__logo" href="/" aria-label="Sosun Fihaara home">
        <img src="/logo.png" alt="Sosun Fihaara logo">
      </a>
      <input type="checkbox" id="navtoggle" class="nav__check">
      <ul class="nav__links">
        <li><a href="/" aria-current={Astro.url.pathname === "/" ? "page" : undefined}>Home</a></li>
        <li><a href="/about" aria-current={Astro.url.pathname.startsWith("/about") ? "page" : undefined}>About Us</a></li>
        <li><a href="/products" aria-current={Astro.url.pathname.startsWith("/products") ? "page" : undefined}>Products</a></li>
        <li><a href="/brands" aria-current={Astro.url.pathname.startsWith("/brands") ? "page" : undefined}>Brands</a></li>
        <li><a href="/news" aria-current={Astro.url.pathname.startsWith("/news") ? "page" : undefined}>News</a></li>
        <li><a href="/recipes" aria-current={Astro.url.pathname.startsWith("/recipes") ? "page" : undefined}>Recipes</a></li>
      </ul>
      <div class="nav__cta">
        <a href="/contact" class="btn btn--gold">CONTACT US</a>
        <label class="nav__burger" for="navtoggle" aria-label="Toggle menu">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><line x1="3" y1="7" x2="21" y2="7"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="17" x2="21" y2="17"></line></svg>
        </label>
      </div>
    </nav>
  </div>
</header>