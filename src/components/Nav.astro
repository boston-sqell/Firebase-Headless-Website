---
const pathname = Astro.url.pathname;
---
<!-- ===== HEADER ===== -->
<header id="header" class="fixed top-0 left-0 w-full z-50 transition-transform duration-500 translate-y-0">
  <div class="header-gradient">
    <!-- Desktop nav -->
    <div class="hidden lg:flex items-stretch h-[6vw] min-h-[72px] px-[5.2vw]">
      <div class="flex items-end pb-[2vw] flex-1">
        <a href="/" class="flex items-center gap-2" aria-label="Sosun Fihaara – go to homepage">
          <img src="/logo.png" alt="Sosun Fihaara" class="h-10 w-auto object-contain" style="height: 40px !important; width: auto !important;" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <div style="display:none" class="w-10 h-10 bg-[#917151] rounded-lg items-center justify-center flex-shrink-0">
            <span class="text-white font-bold text-lg font-alumni">SF</span>
          </div>
        </a>
      </div>
      <nav aria-label="Main navigation" class="flex items-start justify-center pt-[2vw] w-[50%] border-b border-white/20 px-[2vw]">
        <ul class="flex w-full justify-between max-w-[700px]" role="list">
          {[{label: 'Home', href: '/'}, {label: 'About Us', href: '/about'}, {label: 'Products', href: '/products'}, {label: 'Brands', href: '/brands'}, {label: 'News', href: '/news'}, {label: 'Recipes', href: '/recipes'}].map(item => {
            const isCurrent = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
            return (
              <li>
                <a href={item.href} aria-current={isCurrent ? "page" : undefined} class="font-lato text-[0.83vw] font-normal uppercase tracking-tight hover:font-bold transition-all leading-[3.6vw] whitespace-nowrap" style={isCurrent ? "color: #a8d5ba !important; font-weight: bold; border-bottom: 2px solid #a8d5ba; padding-bottom: 2px;" : "color: #ffffff !important;"}>{item.label}</a>
              </li>
            );
          })}
        </ul>
      </nav>
      <div class="flex items-stretch justify-end border-b border-white/20 flex-1">
        <a href="tel:+9603313020" aria-label="Call us at +960 331 3020" class="flex flex-col items-center justify-center gap-[0.5vw] bg-gradient-to-b from-[#0ea44b00] to-[#0ea44b] px-[0.94vw] text-white border-0 cursor-pointer hover:to-[#0b8a3d] transition-all no-underline ml-auto" style="color: #ffffff !important;">
          <span class="font-lato text-[0.83vw] font-normal uppercase tracking-[2px]">Call Us Now</span>
          <span class="font-alumni text-[1.5vw] font-bold tracking-wide">+960 331 3020</span>
        </a>
      </div>
    </div>
    <!-- Mobile nav -->
    <div class="flex lg:hidden items-center justify-between px-5 h-[72px]">
      <a href="/" aria-label="Sosun Fihaara homepage" class="flex items-center gap-2">
        <img src="/logo.png" alt="Sosun Fihaara" class="h-9 w-auto object-contain" style="height: 36px !important; width: auto !important;" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div style="display:none" class="w-9 h-9 bg-[#917151] rounded-lg items-center justify-center">
          <span class="text-white font-bold font-alumni">SF</span>
        </div>
        <span class="text-white font-alumni font-bold text-lg tracking-wider">SOSUN FIHAARA</span>
      </a>
      <button id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false" class="text-white p-1 bg-transparent border-0 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#0d2c22] hidden flex-col px-6 pt-6 pb-10">
  <div class="flex items-center justify-between mb-10">
    <span class="text-white font-alumni font-bold text-xl tracking-wider">SOSUN FIHAARA</span>
    <button id="mobile-menu-close" aria-label="Close menu" class="text-white p-1 bg-transparent border-0 cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <nav>
    <ul class="flex flex-col gap-5">
      {['Home,/', 'About Us,/about', 'Products,/products', 'Brands,/brands', 'News,/news', 'Recipes,/recipes', 'Contact,/contact'].map(item => {
        const [label, href] = item.split(',');
        const isCurrent = href === '/' ? pathname === '/' : pathname.startsWith(href);
        return (
          <li><a href={href} aria-current={isCurrent ? "page" : undefined} class="font-alumni text-[48px] leading-none uppercase tracking-tight hover:text-[#a8d5ba] transition-colors no-underline" style={isCurrent ? "color: #a8d5ba !important;" : "color: #ffffff !important;"}>{label}</a></li>
        );
      })}
    </ul>
  </nav>
  <div class="mt-auto pt-8 border-t border-white/10">
    <a href="tel:+9603313020" class="font-alumni text-[#917151] text-2xl tracking-wide no-underline">+960 331 3020</a>
  </div>
</div>

<script>
  // Header hide/show on scroll
  let lastY = 0;
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (header) header.style.transform = (y > lastY && y > 100) ? 'translateY(-100%)' : 'translateY(0)';
    lastY = y;
  }, { passive: true });

  // Mobile menu
  const menu = document.getElementById('mobile-menu');
  const openBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  function openMenu() {
    menu?.classList.remove('hidden'); menu?.classList.add('flex');
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    menu?.classList.add('hidden'); menu?.classList.remove('flex');
    openBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
</script>