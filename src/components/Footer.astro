---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-[#083C2B] text-white pt-16 pb-8 border-t border-[#D8D4C9]/10" aria-label="Site footer">
  <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-12">
      <!-- Col 1: Company summary -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4 text-white no-underline">
          <img src="/logo.png" alt="Sosun Fihaara" class="h-8 w-auto object-contain filter brightness-0 invert" style="height: 32px !important;" />
          <span class="font-display font-bold text-lg tracking-tight text-white">SOSUN FIHAARA</span>
        </a>
        <p class="text-[#DDEBE2]/75 text-sm font-body max-w-sm leading-relaxed mb-6">
          Connecting global essentials to every Maldivian island. Partnering with trusted international brands to deliver quality retail, wholesale, and hospitality supply since 1980.
        </p>
        <p class="text-xs text-[#DDEBE2]/40 font-body">
          Established 1980 · Malé, Maldives
        </p>
      </div>

      <!-- Col 2: Products and brands -->
      <div>
        <h3 class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-4">Products & Brands</h3>
        <ul class="flex flex-col gap-2 font-body text-sm">
          <li><a href="/products" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">All Products</a></li>
          <li><a href="/products?cat=Confectionery" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Confectionery</a></li>
          <li><a href="/products?cat=Beverages" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Beverages</a></li>
          <li><a href="/products?cat=Pantry" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Pantry Staples</a></li>
          <li><a href="/brands" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Brand Partners</a></li>
        </ul>
      </div>

      <!-- Col 3: Business solutions -->
      <div>
        <h3 class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-4">Business Solutions</h3>
        <ul class="flex flex-col gap-2 font-body text-sm">
          <li><a href="/distribution/retail-supply" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Retail Supply</a></li>
          <li><a href="/distribution/hospitality-food-service" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Hospitality & Food Service</a></li>
          <li><a href="/distribution/brand-partnerships" class="text-[#DDEBE2]/75 hover:text-white transition-colors no-underline">Brand Partnerships</a></li>
          <li><a href="/request-quote" class="text-[#C5A578] hover:text-white transition-colors font-bold no-underline">Request a B2B Quote</a></li>
        </ul>
      </div>

      <!-- Col 4: Contact details & Hours -->
      <div>
        <h3 class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-4">Contact & Hours</h3>
        <address class="not-italic flex flex-col gap-3 font-body text-sm text-[#DDEBE2]/75">
          <p>
            <span class="block text-xs text-[#DDEBE2]/40 uppercase font-bold mb-0.5">Address</span>
            Sosun Fihaara, Moosa Ibrahim Didi Goalhi,<br />Malé, Maldives
          </p>
          <p>
            <span class="block text-xs text-[#DDEBE2]/40 uppercase font-bold mb-0.5">Phone</span>
            <a href="tel:+9603313020" class="text-[#C5A578] font-bold hover:text-white transition-colors no-underline text-base">+960 331 3020</a>
          </p>
          <p>
            <span class="block text-xs text-[#DDEBE2]/40 uppercase font-bold mb-0.5">Email</span>
            <a href="mailto:info@sosunfihaara.com" class="text-white hover:text-[#C5A578] transition-colors no-underline">info@sosunfihaara.com</a>
          </p>
          <p>
            <span class="block text-xs text-[#DDEBE2]/40 uppercase font-bold mb-0.5">Operating Hours</span>
            Mon – Sat · 9:00 AM – 6:00 PM
          </p>
        </address>
      </div>
    </div>

    <!-- Bottom bar with Social links, legal and copyright -->
    <div class="pt-8 border-t border-[#DDEBE2]/10 flex flex-col md:flex-row items-center justify-between gap-4 font-body text-xs text-[#DDEBE2]/40">
      <div class="flex flex-wrap gap-6 items-center">
        <p>© {year} Sosun Fihaara. All rights reserved.</p>
        <span class="hidden md:inline">·</span>
        <a href="/privacy" class="hover:text-white transition-colors no-underline">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors no-underline">Terms of Service</a>
        <a href="/accessibility" class="hover:text-white transition-colors no-underline">Accessibility Statement</a>
      </div>
      
      <!-- Social links -->
      <div class="flex items-center gap-4">
        <a href="https://web.facebook.com/SosunFihaara" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-[#DDEBE2]/60 hover:text-white transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-[#DDEBE2]/60 hover:text-white transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
