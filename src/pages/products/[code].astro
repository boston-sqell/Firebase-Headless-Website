---
import Layout from '../../layouts/Layout.astro';
import { getCmsData } from '../../lib/cms';
import type { Product } from '../../lib/cms';
import { getProductPackText, getProductPriceText } from '../../lib/product-pricing';

const { code } = Astro.params;
const { products } = await getCmsData();
const matches = products.filter((p: Product) => String(p.code) === code);
if (matches.length > 1) {
  console.warn(JSON.stringify({
    severity: 'WARNING',
    message: 'duplicate_product_code',
    code,
    count: matches.length,
    hint: 'Fix duplicate product codes in the admin panel (/admin/products).',
  }));
}
const product = matches[0];

if (!product) {
  return Astro.redirect('/products');
}

const description = `${product.name} by ${product.brandName} -- ${product.category}${product.packSize ? `, ${product.packSize}` : ''}. Available wholesale and retail from Sosun Fihaara in the Maldives.`;

const quoteParams = new URLSearchParams({
  product: product.name,
  brand: product.brandName,
  code: String(product.code),
});

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  image: product.image,
  description,
  brand: { "@type": "Brand", name: product.brandName },
  sku: product.code,
  category: product.category,
  ...(product.price ? {
    offers: {
      "@type": "Offer",
      priceCurrency: "MVR",
      price: product.price.replace(/,/g, ''),
      availability: "https://schema.org/InStock",
    },
  } : {}),
};
---

<Layout title={`${product.name} | Sosun Fihaara`} description={description} image={product.image}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
  <main>
    <section class="section bg-cream" style="padding-top: 120px;">
      <div class="container">
        <div style="display: flex; gap: 40px; align-items: flex-start; max-width: 900px; margin: 0 auto; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
          <div style="flex: 1; display: flex; align-items: center; justify-content: center; background: #fff; border-radius: 8px; padding: 20px;">
            <img src={product.image} alt={product.name} style="max-width: 100%; max-height: 400px; object-fit: contain;">
          </div>
          <div style="flex: 1;">
            <span class="eyebrow">{product.brandName} &middot; {product.category}</span>
            <h1 style="margin-top: 10px; margin-bottom: 20px;">{product.name}</h1>

            <div style="margin-bottom: 24px;">
              <p style="font-family: var(--font-display); font-weight: 800; color: var(--green); font-size: 24px; margin: 0;">
                {getProductPriceText(product)}
              </p>
              {getProductPackText(product) && <p style="color: var(--muted); margin-top: 5px;">{getProductPackText(product)}</p>}
              <p style="color: var(--muted); font-size: 13px; margin-top: 8px;">Catalogue pricing is subject to stock, volume, and trade-term confirmation.</p>
            </div>

            <a href={`/request-quote?${quoteParams.toString()}`} class="btn btn--gold">Request a Quote for This Product</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
