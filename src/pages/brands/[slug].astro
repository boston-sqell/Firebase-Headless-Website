---
import Layout from '../../layouts/Layout.astro';
import { getCmsData } from '../../lib/cms';
import type { Product, Brand } from '../../lib/cms';
import { getProductPackText, getProductPriceText } from '../../lib/product-pricing';

const { slug } = Astro.params;
const { brands, products: allProducts } = await getCmsData();
const brand = brands.find((b: Brand) => String(b.slug) === slug);

if (!brand) {
  return Astro.redirect('/brands');
}

const products = allProducts.filter((p: Product) => p.brandName === brand.name);
const description = brand.description || `Explore all ${brand.name} products, authorized and distributed in the Maldives by Sosun Fihaara.`;
---

<Layout title={`${brand.name} | Sosun Fihaara`} description={description} image={brand.logo}>
  <main>
    <section class="section bg-cream" style="padding-top: 120px;">
      <div class="container center">
        {brand.logo && brand.logo !== '/logo.png' && (
          <img src={brand.logo} alt={`${brand.name} logo`} style="max-height: 120px; width: auto; object-fit: contain; margin-bottom: 24px;" />
        )}
        <h1 style="margin-bottom: 20px;">{brand.name}</h1>
        <p style="max-width: 600px; margin: 0 auto; color: var(--muted);">Explore all products from {brand.name}. Sosun Fihaara is an authorized distributor of {brand.name} products in the Maldives.</p>
        <a href="/brands" class="btn btn--outline mt-4">View All Brands</a>
      </div>
    </section>

    <section class="section bg-cream" style="padding-top: 0">
      <div class="container">
        <div class="cat-grid">
          {products.length > 0 ? products.map((p: Product) => (
            <article class="pcard pcard--brand">
              <div class="pcard__img">
                <img src={p.image} alt={p.name} loading="lazy">
              </div>
              <span class="pcard__cat">{p.brandName} &middot; {p.category}</span>
              <h3>{p.name}</h3>
              <div style="flex:1 0 auto;margin-bottom:14px">
                {getProductPackText(p) && <p style="color:var(--muted);font-size:12px;margin:0 0 8px">{getProductPackText(p)}</p>}
                <p style="font-family:var(--font-display);font-weight:800;color:var(--green);font-size:17px;margin:0">{getProductPriceText(p)}</p>
              </div>
              <a href={`/products/${p.code}`} class="textlink">Explore More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
            </article>
          )) : (
            <p class="lead" style="grid-column:1/-1;text-align:center;">No products available for {brand.name}.</p>
          )}
        </div>
      </div>
    </section>
  </main>
</Layout>
