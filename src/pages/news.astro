---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="NEWS | Sosun Fihaara"
  description="News and announcements from Sosun Fihaara — new product arrivals, brand partnerships, and company updates from the Maldives' trusted grocery supplier."
>
<main>
<!-- ================= HERO ================= -->
<section class="hero hero--short">
  <div class="container">
    <div class="hero__inner" style="padding: 80px 0 60px;">
      <span class="eyebrow">Latest Updates</span>
      <h1>News &amp; <em>Announcements</em></h1>
      <p>Stay up to date with the latest from Sosun Fihaara — new products, brand partnerships, and company news.</p>
    </div>
  </div>
</section>

<!-- ================= NEWS GRID ================= -->
<section class="section">
  <div class="container">
    <!-- TODO: Replace placeholder articles with real content once a News collection exists in Firestore -->
    <div class="news-grid">
      <article class="news-card">
        <div class="news-card-img" style="background:#0b3d2e;">
          <span class="news-emoji">🆕</span>
        </div>
        <div class="news-card-content">
          <span class="eyebrow news-eyebrow">June 2025 · Products</span>
          <h3 class="news-title">New Product Range Launch</h3>
          <p class="news-desc">Sosun Fihaara expands its portfolio with an exciting new selection of international FMCG brands, now available for wholesale and retail distribution across the Maldives.</p>
          <a href="/contact" class="btn btn--outline news-btn">Get in Touch</a>
        </div>
      </article>

      <article class="news-card">
        <div class="news-card-img" style="background:#1a5c44;">
          <span class="news-emoji">🤝</span>
        </div>
        <div class="news-card-content">
          <span class="eyebrow news-eyebrow">May 2025 · Partnerships</span>
          <h3 class="news-title">Distribution Partnership Expansion</h3>
          <p class="news-desc">We are proud to announce extended distribution agreements with several of our key international brand partners, strengthening supply across all 20 atolls.</p>
          <a href="/contact" class="btn btn--outline news-btn">Get in Touch</a>
        </div>
      </article>

      <article class="news-card">
        <div class="news-card-img" style="background:#0b3d2e;">
          <span class="news-emoji">🏪</span>
        </div>
        <div class="news-card-content">
          <span class="eyebrow news-eyebrow">April 2025 · Company</span>
          <h3 class="news-title">Four Decades of Service</h3>
          <p class="news-desc">Sosun Fihaara celebrates over 40 years of dedicated FMCG distribution in the Maldives. Thank you to all our retail partners, customers, and the communities we serve.</p>
          <a href="/about" class="btn btn--outline news-btn">Our Story</a>
        </div>
      </article>
    </div>

    <div class="news-cta">
      <h3>Stay Connected</h3>
      <p class="news-cta-desc">Want to be the first to know about new products and promotions? Get in touch with our team.</p>
      <a href="/contact" class="btn btn--gold btn--lg news-btn-cta">Contact Us</a>
    </div>
  </div>
</section>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }
  .news-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .news-card-img {
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .news-emoji {
    color: #c8a96e;
    font-size: 3rem;
  }
  .news-card-content {
    padding: 1.5rem;
  }
  .news-eyebrow {
    font-size: 0.7rem;
  }
  .news-title {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.2rem;
  }
  .news-desc {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .news-btn {
    margin-top: 1rem;
    display: inline-block;
  }
  .news-cta {
    text-align: center;
    margin-top: 4rem;
    padding: 3rem;
    background: #faf9f5;
    border-radius: 12px;
  }
  .news-cta-desc {
    color: #555;
    max-width: 500px;
    margin: 1rem auto;
  }
  .news-btn-cta {
    margin-top: 1rem;
    display: inline-block;
  }
</style>
</main>
</Layout>
