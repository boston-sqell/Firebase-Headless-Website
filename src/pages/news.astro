---
import Layout from '../layouts/Layout.astro';
import { getNews } from '../lib/cms';

const news = await getNews();
---

<Layout
  title="NEWS | Sosun Fihaara"
  description="News and announcements from Sosun Fihaara — new product arrivals, brand partnerships, and company updates from the Maldives' trusted grocery supplier."
>
<main>
<!-- ================= HERO ================= -->
<section class="hero hero--short">
  <div class="container">
    <div class="hero__inner" style="padding: 80px 0 60px;">
      <span class="eyebrow">Latest Updates</span>
      <h1>News &amp; <em>Announcements</em></h1>
      <p>Stay up to date with the latest from Sosun Fihaara — new products, brand partnerships, and company news.</p>
    </div>
  </div>
</section>

<!-- ================= NEWS GRID ================= -->
<section class="section">
  <div class="container">
    <!-- Dynamic News Collection -->
    <div class="news-grid">
      {news.map(n => (
        <article class="news-card">
          <div class="news-card-img" style={`background:${n.backgroundColor || '#0b3d2e'};`}>
            {n.image ? (
              <img src={n.image} alt="" style="width:100%;height:100%;object-fit:cover;" />
            ) : (
              <span class="news-emoji">{n.emoji || '📰'}</span>
            )}
          </div>
          <div class="news-card-content">
            <span class="eyebrow news-eyebrow">{n.eyebrow}</span>
            <h3 class="news-title">{n.title}</h3>
            <div class="news-desc" set:html={n.description} />
          </div>
        </article>
      ))}
      {news.length === 0 && <p>No news updates yet. Please check back later!</p>}
    </div>

    <div class="news-cta">
      <h3>Stay Connected</h3>
      <p class="news-cta-desc">Want to be the first to know about new products and promotions? Get in touch with our team.</p>
      <a href="/contact" class="btn btn--gold btn--lg news-btn-cta">Contact Us</a>
    </div>
  </div>
</section>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }
  .news-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }
  .news-card-img {
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .news-emoji {
    color: #c8a96e;
    font-size: 3rem;
  }
  .news-card-content {
    padding: 1.5rem;
  }
  .news-eyebrow {
    font-size: 0.7rem;
  }
  .news-title {
    margin: 0.5rem 0 0.75rem;
    font-size: 1.2rem;
  }
  .news-desc {
    color: #555;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .news-btn {
    margin-top: 1rem;
    display: inline-block;
  }
  .news-cta {
    text-align: center;
    margin-top: 4rem;
    padding: 3rem;
    background: #faf9f5;
    border-radius: 12px;
  }
  .news-cta-desc {
    color: #555;
    max-width: 500px;
    margin: 1rem auto;
  }
  .news-btn-cta {
    margin-top: 1rem;
    display: inline-block;
  }
</style>
</main>
</Layout>
