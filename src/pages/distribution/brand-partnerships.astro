---
// brand-partnerships.astro - Brand Partnerships B2B Detail Page
import Layout from '../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import brandPartnershipsImage from '../../assets/home/brand_partnerships.png';
---

<Layout
  title="Brand Partnerships & Importation | Sosun Fihaara"
  description="Partner with Sosun Fihaara for exclusive import, logistics, and distribution of FMCG brands in the Maldives."
>
  <main class="bg-[#F6F2E8] py-20 min-h-screen pt-28">
    <div class="max-w-[1000px] mx-auto px-5">
      <!-- Breadcrumbs -->
      <div class="mb-6 font-body text-xs text-[#566159] uppercase tracking-wider">
        <a href="/" class="hover:text-[#00663B] no-underline">Home</a> &nbsp;/&nbsp;
        <a href="/distribution" class="hover:text-[#00663B] no-underline">Distribution</a> &nbsp;/&nbsp;
        <span class="text-[#18231D]">Brand Partnerships</span>
      </div>

      <div class="bg-white border border-[#D8D4C9] rounded-2xl overflow-hidden shadow-sm mb-12">
        <div class="aspect-[16/6] w-full bg-[#EAE6DC] overflow-hidden">
          <Picture src={brandPartnershipsImage} formats={['avif', 'webp']} widths={[480, 768, 1024]} sizes="(min-width: 1000px) 1000px, 100vw" alt="Warehouse logistics dock and shipping cargo operations" class="w-full h-full object-cover" />
        </div>

        <div class="p-8 lg:p-12">
          <span class="text-xs font-bold uppercase tracking-wider bg-[#DDEBE2] text-[#00663B] px-3 py-1 rounded-full">
            B2B Services
          </span>

          <h1 class="font-display font-bold text-[#18231D] leading-tight mt-4 mb-6" style="font-size: var(--type-h2);">
            FMCG Brand Partnerships
          </h1>

          <div class="prose font-body text-base text-[#18231D] leading-relaxed max-w-none mb-8">
            <p class="mb-4">
              We act as the gateway and exclusive distributor for global FMCG brand principals looking to enter or scale within the Maldivian market. Our deep local knowledge, established logistics infrastructure, and four decades of market credibility make us the ideal partner.
            </p>
            <h3 class="font-display font-bold text-lg text-[#18231D] mt-6 mb-3">Why Partner With Us?</h3>
            <ul class="list-disc pl-5 mb-6 flex flex-col gap-2">
              <li><strong>End-to-End Market Access:</strong> We handle clearance, importation, warehousing, local compliance, and nationwide distribution.</li>
              <li><strong>Active Brand Building:</strong> Dedicated local marketing, in-store placement, and localized promotions to drive brand awareness.</li>
              <li><strong>Established B2B Accounts:</strong> Direct relationships with major retail chains, local shops, and luxury resorts across 20 atolls.</li>
              <li><strong>Financial & Operational Credibility:</strong> A family-founded local business since 1980, recognized for transparent terms and operational integrity.</li>
            </ul>
          </div>

          <!-- B2B CTA band inside page -->
          <div class="pt-8 border-t border-[#D8D4C9]/40 flex flex-col md:flex-row items-center justify-between gap-6 bg-[#DDEBE2]/30 p-6 rounded-xl">
            <div>
              <h3 class="font-display font-bold text-lg text-[#083C2B] mb-1">Explore B2B Partnership</h3>
              <p class="font-body text-xs text-[#566159] leading-relaxed">
                Schedule a consultation with our importation and brand directors.
              </p>
            </div>
            <div class="flex gap-3 w-full md:w-auto shrink-0 justify-center">
              <a href="/request-quote" class="btn-primary">Become a partner</a>
              <a href="/about" class="btn-secondary">Our Story</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-green);
    color: var(--color-surface) !important;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    height: 44px;
    padding: 0 20px;
    border-radius: 10px;
    border: none;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.16s ease;
  }
  .btn-primary:hover {
    background-color: var(--color-green-dark);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    color: var(--color-green) !important;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    height: 44px;
    padding: 0 20px;
    border-radius: 10px;
    border: 1px solid var(--color-green);
    text-decoration: none;
    transition: background-color 0.16s ease, color 0.16s ease;
  }
  .btn-secondary:hover {
    background-color: var(--color-green);
    color: var(--color-surface) !important;
  }
</style>
