---
import Layout from '../layouts/Layout.astro';
import { getProducts, getBrands, getSiteContent, resolveWixImage } from '../lib/cms';

const [allProducts, brands, site] = await Promise.all([
  getProducts(),
  getBrands(),
  getSiteContent()
]);

const sortedBrands = brands.map((b: any) => b.name).sort();

const brandFilter = Astro.url.searchParams.get('brand') || '';
const catFilter = Astro.url.searchParams.get('cat') || '';
const subFilter = Astro.url.searchParams.get('sub') || '';
const sortFilter = Astro.url.searchParams.get('sort') || '';
const pageStr = Astro.url.searchParams.get('page') || '1';
const page = parseInt(pageStr, 10) || 1;
const pageSize = 24;

let filteredProducts = allProducts.filter((p: any) => {
  if (brandFilter && p.b !== brandFilter) return false;
  if (catFilter && p.cat !== catFilter) return false;
  if (subFilter && p.sub !== subFilter) return false;
  return true;
});

if (sortFilter === 'Name (A–Z)') {
  filteredProducts.sort((a: any, b: any) => a.n.localeCompare(b.n));
} else if (sortFilter === 'Name (Z–A)') {
  filteredProducts.sort((a: any, b: any) => b.n.localeCompare(a.n));
} else if (sortFilter === 'Price (low–high)') {
  filteredProducts.sort((a: any, b: any) => {
    const pa = parseFloat(a.pr?.replace(/,/g, '') || '0');
    const pb = parseFloat(b.pr?.replace(/,/g, '') || '0');
    return pa - pb;
  });
}

const totalProducts = filteredProducts.length;
const products = filteredProducts.slice(0, page * pageSize);
const hasMore = products.length < totalProducts;
---

<Layout title="PRODUCTS | Sosun Fihaara">
<main>


<section class="page-hero" style="background:#0b3d2e">
  <img id="products-hero-img" class="page-hero__img" src="" alt="" style="display:none">
  <div class="container page-hero__inner">
    <h1>Products</h1>
    <p class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; <span>Products</span></p>
  </div>
</section>

<section class="section--tight bg-cream">
  <div class="container">
    <div class="section-head center">
      <h2 style="font-size:clamp(26px,4vw,40px)">Crafted for freshness, sourced for trust</h2>
      <p>From bakery staples to sauces and spices, every product in our range is selected for quality, consistency and flavour — ready for shelves, cafés and kitchens across the Maldives.</p>
    </div>
  </div>
</section>

<!-- PRODUCT CATALOG -->
<section class="section bg-cream" id="product-range" style="padding-top:0">
  <div class="container">

    <div class="cat-toolbar">
      <div class="cat-filters">
        <div class="cat-filter">
          <label for="brandFilter">Filter by brand</label>
          <select id="brandFilter" name="brand" aria-label="Filter by brand">
            <option value="">All Brands</option>
            {sortedBrands.map((b: string) => <option value={b} selected={brandFilter === b}>{b}</option>)}
          </select>
        </div>
        <div class="cat-filter">
          <label for="sortFilter">Sort by</label>
          <select id="sortFilter" name="sort" aria-label="Sort products">
            <option value="" selected={!sortFilter || sortFilter === 'Featured'}>Featured</option>
            <option value="Name (A–Z)" selected={sortFilter === 'Name (A–Z)'}>Name (A–Z)</option>
            <option value="Name (Z–A)" selected={sortFilter === 'Name (Z–A)'}>Name (Z–A)</option>
            <option value="Price (low–high)" selected={sortFilter === 'Price (low–high)'}>Price (low–high)</option>
          </select>
        </div>
      </div>
      <p class="cat-results"><span id="resultCount">Showing <strong>{Math.min(products.length, totalProducts)}</strong> of {totalProducts} products</span> &nbsp;<a href="/products#product-range" class="clear" id="clearFilters">Clear filters</a></p>
    </div>

    <div class="catalog">
      <aside class="cat-aside" aria-label="Product categories">
        <h3>Categories</h3>
        <nav class="cat-list">
          <a href="#product-range" class="cat-link is-active" id="allProducts" data-cat="" data-sub="">All Products <span class="plus" aria-hidden="true">+</span></a>
          <details class="cat-acc"><summary>Baby Care <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Baby Care" data-sub="" style="font-weight:600;color:var(--green)">All Baby Care</a><a class="cat-link" href="#product-range" data-cat="Baby Care" data-sub="Baby Foods">Baby Foods</a><a class="cat-link" href="#product-range" data-cat="Baby Care" data-sub="Wipes">Wipes</a></div></details>
          <details class="cat-acc"><summary>Baking <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Baking" data-sub="" style="font-weight:600;color:var(--green)">All Baking</a><a class="cat-link" href="#product-range" data-cat="Baking" data-sub="Cake Mix">Cake Mix</a><a class="cat-link" href="#product-range" data-cat="Baking" data-sub="Cooking Chocolate">Cooking Chocolate</a></div></details>
          <details class="cat-acc"><summary>Beverages <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="" style="font-weight:600;color:var(--green)">All Beverages</a><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="Basil Seed Drinks">Basil Seed Drinks</a><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="Energy Drink">Energy Drink</a><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="Iced Coffee">Iced Coffee</a><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="Juice Drink">Juice Drink</a><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="Smoothies">Smoothies</a><a class="cat-link" href="#product-range" data-cat="Beverages" data-sub="Yogurt Drink">Yogurt Drink</a></div></details>
          <details class="cat-acc"><summary>Chocolate <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Chocolate" data-sub="" style="font-weight:600;color:var(--green)">All Chocolate</a><a class="cat-link" href="#product-range" data-cat="Chocolate" data-sub="Toppings">Toppings</a></div></details>
          <details class="cat-acc"><summary>Confectionery <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Confectionery" data-sub="" style="font-weight:600;color:var(--green)">All Confectionery</a><a class="cat-link" href="#product-range" data-cat="Confectionery" data-sub="Dates">Dates</a><a class="cat-link" href="#product-range" data-cat="Confectionery" data-sub="Dessert Mix">Dessert Mix</a><a class="cat-link" href="#product-range" data-cat="Confectionery" data-sub="Sweeteners">Sweeteners</a></div></details>
          <details class="cat-acc"><summary>Cooking Ingredients <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Cooking Ingredients" data-sub="" style="font-weight:600;color:var(--green)">All Cooking Ingredients</a><a class="cat-link" href="#product-range" data-cat="Cooking Ingredients" data-sub="Coconut Milk">Coconut Milk</a><a class="cat-link" href="#product-range" data-cat="Cooking Ingredients" data-sub="Pastes &amp; Preserves">Pastes &amp; Preserves</a></div></details>
          <details class="cat-acc"><summary>Dairy <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Dairy" data-sub="" style="font-weight:600;color:var(--green)">All Dairy</a><a class="cat-link" href="#product-range" data-cat="Dairy" data-sub="Butter &amp; Margarine">Butter &amp; Margarine</a><a class="cat-link" href="#product-range" data-cat="Dairy" data-sub="Cheese">Cheese</a><a class="cat-link" href="#product-range" data-cat="Dairy" data-sub="Milk">Milk</a><a class="cat-link" href="#product-range" data-cat="Dairy" data-sub="Yogurt">Yogurt</a></div></details>
          <details class="cat-acc"><summary><a class="cat-link" href="#product-range" data-cat="Mosquito Repellent" data-sub="" style="all:unset;cursor:pointer;flex:1">Mosquito Repellent</a> <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Mosquito Repellent" data-sub="">All Mosquito Repellent</a></div></details>
          <details class="cat-acc"><summary>Recipe's &amp; Spices <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Recipe's &amp; Spices" data-sub="" style="font-weight:600;color:var(--green)">All Recipe's &amp; Spices</a><a class="cat-link" href="#product-range" data-cat="Recipe's &amp; Spices" data-sub="Recipe's">Recipe's</a><a class="cat-link" href="#product-range" data-cat="Recipe's &amp; Spices" data-sub="Spices">Spices</a></div></details>
          <details class="cat-acc"><summary>Sauces &amp; Dressings <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Sauces &amp; Dressings" data-sub="" style="font-weight:600;color:var(--green)">All Sauces &amp; Dressings</a><a class="cat-link" href="#product-range" data-cat="Sauces &amp; Dressings" data-sub="Dressings">Dressings</a><a class="cat-link" href="#product-range" data-cat="Sauces &amp; Dressings" data-sub="Mustard">Mustard</a><a class="cat-link" href="#product-range" data-cat="Sauces &amp; Dressings" data-sub="Sauces">Sauces</a></div></details>
          <details class="cat-acc"><summary>Snacks <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Snacks" data-sub="" style="font-weight:600;color:var(--green)">All Snacks</a><a class="cat-link" href="#product-range" data-cat="Snacks" data-sub="Biscuits">Biscuits</a><a class="cat-link" href="#product-range" data-cat="Snacks" data-sub="Nuts">Nuts</a></div></details>
          <details class="cat-acc"><summary>Spreads &amp; Mayo <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Spreads &amp; Mayo" data-sub="" style="font-weight:600;color:var(--green)">All Spreads &amp; Mayo</a><a class="cat-link" href="#product-range" data-cat="Spreads &amp; Mayo" data-sub="Chocolate Spreads">Chocolate Spreads</a><a class="cat-link" href="#product-range" data-cat="Spreads &amp; Mayo" data-sub="Cream">Cream</a><a class="cat-link" href="#product-range" data-cat="Spreads &amp; Mayo" data-sub="Mayonnaise">Mayonnaise</a><a class="cat-link" href="#product-range" data-cat="Spreads &amp; Mayo" data-sub="Peanut Butter">Peanut Butter</a><a class="cat-link" href="#product-range" data-cat="Spreads &amp; Mayo" data-sub="Sandwich Spreads">Sandwich Spreads</a></div></details>
          <details class="cat-acc"><summary>Staple Foods <span class="plus" aria-hidden="true">+</span></summary><div class="cat-sub"><a class="cat-link" href="#product-range" data-cat="Staple Foods" data-sub="" style="font-weight:600;color:var(--green)">All Staple Foods</a><a class="cat-link" href="#product-range" data-cat="Staple Foods" data-sub="Atta">Atta</a><a class="cat-link" href="#product-range" data-cat="Staple Foods" data-sub="Wraps">Wraps</a><a class="cat-link" href="#product-range" data-cat="Staple Foods" data-sub="Yeast">Yeast</a></div></details>
        </nav>
      </aside>

      <div>
        <div class="cat-grid" id="catGrid">
          {products.map((p: any) => (
            <article class="pcard pcard--brand" data-brand={p.b} data-cat={p.cat} data-sub={p.sub} data-price={p.pr ? p.pr.replace(/,/g, '') : '0'} data-name={p.n}>
              <div class="pcard__img">
                <img src={p.img} alt={p.n} loading="lazy">
              </div>
              <span class="pcard__cat">{p.b} &middot; {p.cat}</span>
              <h3>{p.n}</h3>
              <div style="flex:1 0 auto;margin-bottom:14px">
                {p.p && <p style="color:var(--muted);font-size:12px;margin:0 0 8px">Pack: {p.p}</p>}
                {p.pr ? 
                  <p style="font-family:var(--font-display);font-weight:800;color:var(--green);font-size:17px;margin:0">MVR {p.pr}</p> 
                  : <p style="font-family:var(--font-display);font-weight:700;color:var(--muted);font-size:13px;margin:0">Request price</p>
                }
              </div>
              <a href={`/products/${p.c}`} class="textlink">Explore More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
            </article>
          ))}
        </div>
        {products.length === 0 && (
          <p class="lead" style="grid-column:1/-1;text-align:center;padding:40px 0">
            No products match these filters. <a class="textlink" href="/contact">Ask us &rarr;</a>
          </p>
        )}
        <div class="center" style="margin-top:40px">
          {hasMore && (
            <a href={`/products?page=${page + 1}&brand=${encodeURIComponent(brandFilter)}&cat=${encodeURIComponent(catFilter)}&sub=${encodeURIComponent(subFilter)}&sort=${encodeURIComponent(sortFilter)}#product-range`} id="loadMore" class="btn btn--ghost btn--lg">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"></path></svg>
              Load More
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
  <script>
    function updateUrl(params) {
      const url = new URL(window.location.href);
      for (const [k, v] of Object.entries(params)) {
        if (v) url.searchParams.set(k, v);
        else url.searchParams.delete(k);
      }
      url.hash = 'product-range';
      window.location.href = url.toString();
    }

    document.getElementById('brandFilter')?.addEventListener('change', (e) => {
      updateUrl({ brand: e.target.value, page: '1' });
    });
    
    document.getElementById('sortFilter')?.addEventListener('change', (e) => {
      updateUrl({ sort: e.target.value, page: '1' });
    });
    
    document.querySelectorAll('.cat-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        updateUrl({ cat: link.dataset.cat || '', sub: link.dataset.sub || '', page: '1' });
      });
    });
  </script>
</section>

<!-- COMPARISON TABLE (unique) -->
<section class="section bg-cream">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Two ways to buy</span>
      <h2>Wholesale or retail — <span class="accent">we supply both</span></h2>
      <p>Whether you're stocking a store or buying for your household, here's how each route works.</p>
    </div>
    <div style="overflow-x:auto">
      <table class="compare">
        <caption>Wholesale terms are tailored per account — request a quote for current pricing.</caption>
        <thead>
          <tr><th scope="col">What you get</th><th scope="col">Wholesale</th><th scope="col" class="hl">Retail</th></tr>
        </thead>
        <tbody>
          <tr><th scope="row">Ideal for</th><td>Retailers, cafés, institutions</td><td class="hl">Households &amp; end customers</td></tr>
          <tr><th scope="row">Order volume</th><td>Cases &amp; bulk pallets</td><td class="hl">Single &amp; small packs</td></tr>
          <tr><th scope="row">Pricing</th><td>Volume &amp; trade terms</td><td class="hl">Standard shelf pricing</td></tr>
          <tr><th scope="row">Island-wide delivery</th><td class="yes">✓ Included</td><td class="hl yes">✓ Available</td></tr>
          <tr><th scope="row">Dedicated trade support</th><td class="yes">✓ Yes</td><td class="hl">On request</td></tr>
          <tr><th scope="row">Authentic, quality-assured stock</th><td class="yes">✓ Always</td><td class="hl yes">✓ Always</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section bg-cream" style="padding-top:0">
  <div class="container"><div class="cta-band">
    <h2>Need a tailored wholesale quote?</h2>
    <p>Send us your product list and order volumes — our trade team will get back to you fast.</p>
    <div class="btns"><a href="/contact" class="btn btn--gold btn--lg">Get a Quote</a><a href="/brands" class="btn btn--on-dark btn--lg">View Brands</a></div>
  </div></div>
</section>

</main>
</Layout>
