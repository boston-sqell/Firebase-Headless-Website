---
import Layout from '../layouts/Layout.astro';
import { getRecipes } from '../lib/cms';

const recipes = await getRecipes();
const featured = recipes.find(r => r.featured);
const others = recipes.filter(r => !r.featured || r.id !== featured?.id);
---

<Layout
  title="RECIPES | Sosun Fihaara"
  description="Simple, flavourful recipes made with Sosun Fihaara products — everyday meals and festive dishes built on trusted ingredients."
>
<main>

<section class="page-hero">
  <img class="page-hero__img" src="/images/recipes/hero.jpg" alt="Home cook preparing a meal with fresh ingredients" loading="eager" onerror="this.style.display='none'">
  <div class="container page-hero__inner">
    <h1>Recipes</h1>
    <p class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; <span>Recipes</span></p>
  </div>
</section>

<section class="section--tight bg-cream">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Recipes made simple</span>
      <h2>Flavour journeys for <span class="accent">food lovers everywhere</span></h2>
      <p>Recipes come alive when made with Sosun Fihaara products. Whether it's a weeknight meal or a festive feast, our trusted ingredients make every dish easier, tastier and more memorable.</p>
    </div>
  </div>
</section>

<!-- FEATURED RECIPE -->
{featured && (
<section class="section bg-cream" style="padding-top:0">
  <div class="container">
    <div class="split" style="background:var(--white);border:1px solid var(--line);border-radius:var(--r-lg);overflow:hidden;box-shadow:var(--shadow);gap:0">
      <div class="split__media" style="border-radius:0;box-shadow:none">
        {featured.image && <img src={featured.image} alt={featured.title} loading="lazy" style="height:100%">}
      </div>
      <div style="padding:clamp(28px,4vw,52px);display:flex;flex-direction:column;justify-content:center">
        <span class="pill">Featured of the week</span>
        <h2 style="font-size:clamp(28px,3.6vw,42px);margin:16px 0 8px">{featured.title}</h2>
        <div set:html={featured.description} />
        <ul class="recipe-facts mt-4">
          <li><strong>{featured.prepTime || '0'}</strong><span>Min Prep</span></li>
          <li><strong>{featured.cookTime || '0'}</strong><span>Min Cook</span></li>
        </ul>
      </div>
    </div>
  </div>
</section>
)}

<!-- RECIPE GRID -->
<section class="section bg-white" style="padding-top:0">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">More to cook</span>
      <h2>Dishes built on <span class="accent">brands you trust</span></h2>
    </div>
    <div class="grid grid-3">
      {others.map(r => (
        <article class="card">
          <div class="card__media">
            {r.image && <img src={r.image} alt={r.title} loading="lazy">}
          </div>
          <div class="card__body">
            <div class="meta" style="margin-bottom:10px">
              {r.pill && <span class="pill">{r.pill}</span>}
              {r.pill && r.meta && <span class="dot"></span>}
              {r.meta && <span>{r.meta}</span>}
            </div>
            <h3>{r.title}</h3>
            <div class="recipe-desc" set:html={r.description} />
            <ul class="recipe-facts mt-3">
              <li><strong>{r.prepTime || '0'}</strong><span>Prep</span></li>
              <li><strong>{r.cookTime || '0'}</strong><span>Cook</span></li>
            </ul>
          </div>
        </article>
      ))}
      {others.length === 0 && <p>More recipes coming soon!</p>}
    </div>
  </div>
</section>

<section class="section bg-cream">
  <div class="container"><div class="cta-band">
    <h2>Cooking for a café or kitchen?</h2>
    <p>Source the ingredients behind every recipe — at wholesale prices, delivered island-wide.</p>
    <div class="btns"><a href="/products" class="btn btn--gold btn--lg">View Products</a><a href="/contact" class="btn btn--on-dark btn--lg">Get a Quote</a></div>
  </div></div>
</section>

</main>
</Layout>
