---
import Layout from '../layouts/Layout.astro';
import { getCmsData } from '../lib/cms';
import type { Brand } from '../lib/cms';

let cmsError = false;
let cmsData: Awaited<ReturnType<typeof getCmsData>> = { products: [], brands: [], site: {} };
try {
  const _d = await getCmsData();
  cmsData = _d;
} catch (e) {
  console.error("[page] getCmsData failed:", e);
  cmsError = true;
}
const { brands, site } = cmsData;
const sortedBrands = [...brands].sort((a: Brand, b: Brand) => a.name.localeCompare(b.name));
---

<Layout
  title="BRANDS | Sosun Fihaara"
  description="The world-renowned FMCG brands Sosun Fihaara distributes across the Maldives — authentic products sourced directly from trusted global manufacturers since 1980."
>
<main>
{cmsError && (
  <div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:16px 24px;text-align:center;font-size:15px;">
    &#9888;&#65039; We could not load live data right now. Please refresh the page or try again shortly.
  </div>
)}

<section class="page-hero">
  <img class="page-hero__img" src={site.brandsPageHero || "/brands-hero.jpg"} alt="A spread of branded grocery products in a kitchen" loading="eager" onerror="this.style.display='none'">
  <div class="container page-hero__inner">
    <h1>Brands</h1>
    <p class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; <span>Brands</span></p>
  </div>
</section>

<section class="section--tight bg-cream">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Trusted brands, one partner</span>
      <h2>Expanding our <span class="accent">portfolio</span> of trusted brands</h2>
      <p>A brand is a promise. We represent international names customers already know and trust — and put them within reach of every Maldivian shelf.</p>
    </div>
  </div>
</section>

<!-- BRAND TILES -->
<section class="section bg-cream" style="padding-top:0">
  <div class="container">
    <div class="brand-grid" id="brand-grid-dynamic">
      {sortedBrands.map((b: Brand) => (
        <a class="brand-tile" href={`/brands/${b.slug}`}>
          {b.logo && b.logo !== '/logo.png' && <img src={b.logo} alt={b.name} style="max-height: 80px; object-fit: contain; margin-bottom: 10px;" />}
          <span>{b.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- SUB-DISTRIBUTORS -->
<section class="section bg-white">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Supplying with integrity</span>
      <h2>Authorised <span class="accent">sub-distributors</span></h2>
      <p>Our trusted partners extend Sosun Fihaara's reach to communities across the atolls.</p>
    </div>
    <div class="grid grid-2" style="max-width:840px;margin-inline:auto">
      <article class="card"><div class="card__body">
        <span class="card__tag">Authorised Partner</span>
        <h3>Sarusana</h3>
        <div class="contact-list mt-3" style="gap:14px">
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z" opacity="0"></path><path d="M22 6l-10 7L2 6"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg></span><div><h4>Email</h4><a href="mailto:info@sosunfihaara.com">info@sosunfihaara.com</a></div></div>
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span><div><h4>Address</h4><p>Addu City, Seenu</p></div></div>
        </div>
      </div></article>
      <article class="card"><div class="card__body">
        <span class="card__tag">Authorised Partner</span>
        <h3>Shabnamee Store</h3>
        <div class="contact-list mt-3" style="gap:14px">
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M22 6l-10 7L2 6"></path></svg></span><div><h4>Email</h4><a href="mailto:info@sosunfihaara.com">info@sosunfihaara.com</a></div></div>
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span><div><h4>Address</h4><p>Fonadhoo, Laamu</p></div></div>
        </div>
      </div></article>
    </div>
  </div>
</section>

<section class="section bg-cream">
  <div class="container"><div class="cta-band">
    <h2>Want to carry these brands in your store?</h2>
    <p>Become a Sosun Fihaara stockist and give your customers the names they trust.</p>
    <div class="btns"><a href="/contact" class="btn btn--gold btn--lg">Become a Stockist</a><a href="/products" class="btn btn--on-dark btn--lg">View Products</a></div>
  </div></div>
</section>

</main>
</Layout>
