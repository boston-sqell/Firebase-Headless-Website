---
import Layout from '../layouts/Layout.astro';
---

<Layout title="BRANDS | Sosun Fihaara">
<main>

<section class="page-hero">
  <img class="page-hero__img" src="/placeholder.jpg" alt="A spread of branded grocery products in a kitchen" loading="eager">
  <div class="container page-hero__inner">
    <h1>Brands</h1>
    <p class="crumbs"><a href="index.html">Home</a> &nbsp;/&nbsp; <span>Brands</span></p>
  </div>
</section>

<section class="section--tight bg-cream">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Trusted brands, one partner</span>
      <h2>Expanding our <span class="accent">portfolio</span> of trusted brands</h2>
      <p>A brand is a promise. We represent international names customers already know and trust — and put them within reach of every Maldivian shelf.</p>
    </div>
  </div>
</section>

<!-- BRAND TILES -->
<section class="section bg-cream" style="padding-top:0">
  <div class="container">
    <div class="brand-grid" id="brand-grid-dynamic">
      <a class="brand-tile" href="brand-azime.html"><img class="bl" src="/placeholder.jpg" alt="Azime logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-bruggeman.html"><img class="bl" src="/placeholder.jpg" alt="Bruggeman logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-bumble.html"><img class="bl" src="/placeholder.jpg" alt="Bumble logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-delibreads.html"><span>Delibreads</span></a>
      <a class="brand-tile" href="brand-huxol.html"><img class="bl" src="/placeholder.jpg" alt="Huxol logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-maxfly.html"><img class="bl" src="/placeholder.jpg" alt="Max Fly logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-nawon.html"><img class="bl" src="/placeholder.jpg" alt="Nawon logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-nutberry.html"><span>Nutberry</span></a>
      <a class="brand-tile" href="brand-ondoliva.html"><img class="bl" src="/placeholder.jpg" alt="Ondoliva logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-palmtop.html"><span>Palmtop</span></a>
      <a class="brand-tile" href="brand-pascual.html"><img class="bl" src="/placeholder.jpg" alt="Pascual logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-picnic.html"><img class="bl" src="/placeholder.jpg" alt="Picnic logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-pillsbury.html"><img class="bl" src="/placeholder.jpg" alt="Pillsbury logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-promina.html"><img class="bl" src="/placeholder.jpg" alt="Promina logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-real-thai.html"><img class="bl" src="/placeholder.jpg" alt="Real Thai logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-remia.html"><img class="bl" src="/placeholder.jpg" alt="Remia logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-sotudex.html"><img class="bl" src="/placeholder.jpg" alt="Sotudex logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-tai-sun.html"><img class="bl" src="/placeholder.jpg" alt="Tai Sun logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-wardat-al-mashreq.html"><span>Wardat Al Mashreq</span></a>
      <a class="brand-tile" href="brand-youngs.html"><img class="bl" src="/placeholder.jpg" alt="Young's logo" loading="lazy"></a>
      <a class="brand-tile" href="brand-zaara.html"><span>Zaara</span></a>
    </div>
  </div>
</section>

<!-- SUB-DISTRIBUTORS -->
<section class="section bg-white">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Supplying with integrity</span>
      <h2>Authorised <span class="accent">sub-distributors</span></h2>
      <p>Our trusted partners extend Sosun Fihaara's reach to communities across the atolls.</p>
    </div>
    <div class="grid grid-2" style="max-width:840px;margin-inline:auto">
      <article class="card"><div class="card__body">
        <span class="card__tag">Authorised Partner</span>
        <h3>Sarusana</h3>
        <div class="contact-list mt-3" style="gap:14px">
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z" opacity="0"></path><path d="M22 6l-10 7L2 6"></path><rect x="2" y="4" width="20" height="16" rx="2"></rect></svg></span><div><h4>Email</h4><a href="mailto:info@sosunfihaara.com">info@sosunfihaara.com</a></div></div>
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span><div><h4>Address</h4><p>Addu City, Seenu</p></div></div>
        </div>
      </div></article>
      <article class="card"><div class="card__body">
        <span class="card__tag">Authorised Partner</span>
        <h3>Shabnamee Store</h3>
        <div class="contact-list mt-3" style="gap:14px">
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M22 6l-10 7L2 6"></path></svg></span><div><h4>Email</h4><a href="mailto:info@sosunfihaara.com">info@sosunfihaara.com</a></div></div>
          <div class="contact-item"><span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span><div><h4>Address</h4><p>Fonadhoo, Laamu</p></div></div>
        </div>
      </div></article>
    </div>
  </div>
</section>

<section class="section bg-cream">
  <div class="container"><div class="cta-band">
    <h2>Want to carry these brands in your store?</h2>
    <p>Become a Sosun Fihaara stockist and give your customers the names they trust.</p>
    <div class="btns"><a href="contact.html" class="btn btn--gold btn--lg">Become a Stockist</a><a href="products.html" class="btn btn--on-dark btn--lg">View Products</a></div>
  </div></div>
</section>

</main>
</Layout>
