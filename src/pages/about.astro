---
import Layout from '../layouts/Layout.astro';
import { getSiteContent, getMilestones } from '../lib/cms';
import MilestoneArt from '../components/MilestoneArt.astro';

const site = await getSiteContent();
const milestones = await getMilestones();

// Fallback milestones if none exist yet, just to keep the site looking good until populated
const displayMilestones = milestones.length > 0 ? milestones : [
  { year: '1980', chapter: 'Our Beginning', title: 'A store on<br>Majeedhee Magu', body: 'In 1980, our founders acquired a modest store on Mal&eacute;\'s most vibrant commercial street. It was more than a shop &mdash; it was the seed of a dream, planted in the heart of the Maldives. From those first shelves, a legacy began to take shape.' },
  { year: '1995', chapter: 'The Early Years', title: 'Expo Investments &amp;<br>First Imports', body: 'Fifteen years into our journey, we formalized our vision with the establishment of Expo Investments. Our first foray into imports &mdash; Promina baby food &mdash; marked our belief that Maldivians deserved access to quality from around the world. SOSUN was growing beyond a single store.' },
  { year: '2010', chapter: 'Growing Our Portfolio', title: 'Sosun Fihaara<br>Opens for Trade', body: 'The name Sosun Fihaara became our identity. A dedicated retail space bringing our curated selection under one roof &mdash; it became the destination Maldivians trusted for quality, variety, and value. A real store, a real commitment.' },
  { year: '2014', chapter: 'Serving Maldives', title: 'Sosun Mart<br>Comes to Mal&eacute;', body: 'We expanded with Sosun Mart &mdash; bringing a new retail format closer to the neighbourhoods of the capital. Shorter distances, more choices, and the same quality Maldivians had come to expect. SOSUN was becoming part of the everyday routine.' },
  { year: '2018', chapter: 'Building Partnerships', title: 'Sosun Fihaara<br>Hulhumale\' Opens', body: 'As Hulhumale\' grew into a city of its own, SOSUN Fihaara grew with it. Our Hulhumale\' location extended our reach to a new generation of residents &mdash; families, young professionals, and a community on the rise. The island was expanding; so were we.' },
  { year: '2021', chapter: 'Innovation &amp; Scale', title: 'Sosun Bandharu<br>at North Harbour', body: 'North Harbour became the home of Sosun Bandharu &mdash; our wholesale trade hub. A purpose-built facility for scale and efficiency, Bandharu marked our evolution from retail into a comprehensive distribution network, serving businesses across the islands.' },
  { year: '2025', chapter: 'Today', title: '40+ Years &amp; a<br>Refreshed Identity', body: 'In our 40th year, we chose not just to celebrate our past &mdash; but to reimagine our future. A refreshed brand identity, rooted in heritage and designed for tomorrow. SOSUN Fihaara stands taller, bolder, and more committed than ever to the Maldives we love.' },
];

---

<Layout
  title="Our Story | Sosun Fihaara"
  description="Four decades, four directors, one unwavering commitment to the people of the Maldives. The story of Sosun Fihaara, from a single store on Majeedhee Magu to a nationwide FMCG distribution network."
>
<main>

  <!-- ═══ HERO ═══════════════════════════════════════════ -->
  <section class="story-hero">
    <div class="story-hero__inner">
      <p class="story-eyebrow">Est. 1980 &nbsp;&middot;&nbsp; Mal&eacute;, Maldives</p>
      <h1 class="story-title" set:html={site.aboutHeroHeading?.replace(/\n/g, '<br>') || 'SOSUN<br>FIHAARA'}></h1>
      <p class="story-sub">{site.aboutHeroSubtext || 'Decades of Growing Maldives'}</p>
      <div class="story-divider"></div>
      <p class="story-desc">{site.aboutHeroDesc || 'From a single store on Majeedhee Magu to a network woven into the fabric of Maldivian daily life — this is our story.'}</p>
      <p class="story-dates">Since <strong>1980</strong></p>
    </div>
    <div class="scroll-cue">
      <div class="mouse"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ═══ OPENING ════════════════════════════════════════ -->
  <section class="section bg-cream">
    <div class="container" style="max-width:720px; text-align:center;">
      <span class="eyebrow">Our Journey</span>
      <p class="story-quote" style="margin-top:22px;" set:html={`&ldquo;${site.aboutJourneyQuote?.replace(/\n/g, '<br>') || 'Four decades. Four directors.<br>One unwavering commitment to the people of Maldives.'}&rdquo`}></p>
      <div class="gold-bar"></div>
      <p style="color:var(--muted); font-size:17px; line-height:1.9;">{site.aboutJourneyDesc || 'What began as a humble store has grown into a trusted household name — a company woven into the fabric of everyday Maldivian life. Behind every milestone stood a team that believed in building something lasting.'}</p>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══════════════════════════════════════ -->
  <section class="story-timeline bg-white" id="timeline">
    <div class="story-spine-track">
      <div class="story-spine-fill" id="spineFill"></div>
    </div>

    <div class="section-head center" style="padding:80px 24px 48px; margin-bottom:0;">
      <span class="eyebrow">A Legacy in Time</span>
      <h2 style="margin-top:14px;">The Milestones That Made Us</h2>
    </div>

    {displayMilestones.map((m) => (
      <article class="milestone" data-era={`e${m.year}`}>
        <div class="ms-text">
          <p class="ms-chapter">{m.chapter}</p>
          <h2 class="ms-title" set:html={m.title}></h2>
          <p class="ms-body" set:html={m.body}></p>
        </div>
        <div class="ms-center">
          <div class="ms-dot"></div>
          <span class="ms-year">{m.year}</span>
        </div>
        <div class="ms-img-wrap">
          <MilestoneArt year={m.year} />
        </div>
      </article>
    ))}

  </section><!-- /story-timeline -->

  <!-- ═══ LOOKING FORWARD ════════════════════════════════ -->
  <section class="section story-future bg-dark">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Looking Forward</span>
        <h2>The next chapter is <span class="accent">already beginning.</span></h2>
        <p>We carry our past with pride and our future with purpose. As the Maldives grows, SOSUN Fihaara will be there &mdash; in every neighbourhood, on every table, in every home &mdash; just as we have been for four decades.</p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ════════════════════════════════════════════ -->
  <section class="section bg-cream">
    <div class="container"><div class="cta-band">
      <h2>Forty years of trust, one step at a time</h2>
      <p>Whether you run a single shop or a chain of stores, we'll keep your shelves stocked with the brands customers ask for.</p>
      <div class="btns"><a href="/contact" class="btn btn--gold btn--lg">Get a Quote</a><a href="/products" class="btn btn--on-dark btn--lg">View Products</a></div>
    </div></div>
  </section>

</main>
</Layout>

<script>
  // Reveal milestones as they scroll into view.
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        revealObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.18 });

  document.querySelectorAll('.milestone').forEach((el) => revealObserver.observe(el));

  // Timeline spine fill tracks scroll progress through the section.
  const spineFill = document.getElementById('spineFill');
  const timelineSection = document.getElementById('timeline');

  function updateSpine() {
    if (!timelineSection || !spineFill) return;
    const rect = timelineSection.getBoundingClientRect();
    const totalScroll = rect.height - window.innerHeight;
    const progress = Math.max(0, Math.min(1, -rect.top / Math.max(totalScroll, 1)));
    spineFill.style.height = progress * 100 + '%';
  }

  // Subtle parallax on each era backdrop.
  const parallaxEls = document.querySelectorAll('[data-parallax]');

  function updateParallax() {
    parallaxEls.forEach((el) => {
      const wrap = el.closest('.ms-img-wrap');
      if (!wrap) return;
      const rect = wrap.getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      const distFromCenter = center - window.innerHeight / 2;
      const shift = distFromCenter * 0.12;
      (el as HTMLElement).style.transform = `translateY(${shift}px)`;
    });
  }

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateSpine();
        updateParallax();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  updateSpine();
  updateParallax();
</script>
