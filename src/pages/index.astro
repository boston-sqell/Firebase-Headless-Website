---
import Layout from '../layouts/Layout.astro';
import { getCmsData, getCategories } from '../lib/cms';

let cmsError = false;
let cmsData: any = { products: [], brands: [], site: {} as any };
try {
  const _d = await getCmsData();
  cmsData = _d;
} catch (e) {
  console.error("[page] getCmsData failed:", e);
  cmsError = true;
}
const { products, brands, site } = cmsData;
const categories = await getCategories();
---

<Layout title="HOME | Sosun Fihaara">
<main>
{cmsError && (
  <div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:16px 24px;text-align:center;font-size:15px;">
    &#9888;&#65039; We could not load live data right now. Please refresh the page or try again shortly.
  </div>
)}

<!-- ================= HERO ================= -->
<section class="hero">
  <img id="home-hero-img" class="hero__img" src={site.homeHeroImage} alt="Stocked grocery shelves at a Maldivian retail store" loading="eager">

  <div class="container">
    <div class="hero__inner">
      <span class="eyebrow">Rooted in Trust · Maldives FMCG</span>
      <h1>Stocking the Maldives with <em>everyday essentials</em></h1>
      <p>Four decades of dependable FMCG wholesale and retail distribution — delivering trusted food and grocery brands to retailers and households across every atoll.</p>
      <div class="btns">
        <a href="/products" class="btn btn--gold btn--lg">View Products</a>
      </div>
      <a href="#explore" class="scroll-cue" aria-label="Scroll down to explore" style="margin-top:40px"><span class="mouse" aria-hidden="true"></span>Scroll to explore</a>
    </div>
  </div>
</section>

<!-- ================= STATS ================= -->
<section class="section--tight bg-cream" id="explore">
  <div class="container">
    <div class="stats">
      <div class="stat"><div class="stat__num">40+</div><div class="stat__label">Years of distribution</div></div>
      <div class="stat"><div class="stat__num">25+</div><div class="stat__label">International brands</div></div>
      <div class="stat"><div class="stat__num">300+</div><div class="stat__label">Products in range</div></div>
      <div class="stat"><div class="stat__num">20</div><div class="stat__label">Atolls served</div></div>
    </div>
  </div>
</section>

<!-- ================= INTRO SPLIT ================= -->
<section class="section bg-cream">
  <div class="container">
    <div class="split">
      <div class="split__media">
        <img data-reveal-left src={site.homeIntroImage} alt="Sosun Fihaara distribution warehouse stocked with FMCG goods" loading="lazy">
      </div>
      <div>
        <span class="kicker">Who we are</span>
        <h2>The supply partner Maldivian retailers rely on</h2>
        <p>Sosun Fihaara moves the food and grocery products that keep shops, cafés and kitchens running. From staple foods and dairy to sauces, snacks and baking essentials, we hold the stock, manage the cold chain and deliver on schedule — so you never run dry.</p>
        <p>Wholesale buyers get volume pricing and consistent availability. End customers get authentic, quality brands they recognise and trust. One supplier, the whole shelf.</p>
        <a href="/about" class="textlink mt-3">Our Story
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ================= CATEGORIES ================= -->
<section class="section bg-white">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">What's on the shelf</span>
      <h2>Categories that <span class="accent">cover every aisle</span></h2>
      <p>A complete FMCG range sourced for quality, consistency and taste — supplied at wholesale scale and stocked for retail shelves.</p>
    </div>
    <div class="grid grid-3">
      {categories.map((c: any) => (
        <article class="card">
          <div class="card__media"><img src={c.image} alt={c.name} loading="lazy"></div>
          <div class="card__body">
            <span class="card__tag">{c.tag}</span>
            <h3>{c.name}</h3>
            <p>{c.description}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="center mt-5"><a href="/products" class="btn btn--primary btn--lg">Explore All Products</a></div>
  </div>
</section>

<!-- ================= WHY US / TWO-COLUMN VALUE ================= -->
<section class="section bg-dark">
  <div class="container">
    <div class="split split--reverse">
      <div class="split__media">
        <img data-reveal-right src={site.partnerImage} alt="Delivery truck distributing FMCG goods across the Maldives" loading="lazy">
      </div>
      <div>
        <span class="eyebrow">Why partner with us</span>
        <h2 style="color:#fff">Reliability you can build a business on</h2>
        <p>Stockouts cost sales. Our distribution network, warehousing and island logistics are built to keep your shelves full — with the brands your customers ask for, delivered when you need them.</p>
        <ul class="flow" style="margin-top:20px">
          <li style="display:flex;gap:12px;color:var(--on-dark)"><span style="color:var(--gold);font-weight:800">✓</span> Consistent island-wide availability and fast replenishment</li>
          <li style="display:flex;gap:12px;color:var(--on-dark)"><span style="color:var(--gold);font-weight:800">✓</span> Genuine, quality-assured international brands</li>
          <li style="display:flex;gap:12px;color:var(--on-dark)"><span style="color:var(--gold);font-weight:800">✓</span> Competitive wholesale pricing and trade terms</li>
          <li style="display:flex;gap:12px;color:var(--on-dark)"><span style="color:var(--gold);font-weight:800">✓</span> Cold-chain handling for dairy and chilled lines</li>
        </ul>
        <a href="/contact" class="btn btn--gold mt-4">Become a Stockist</a>
      </div>
    </div>
  </div>
</section>

<!-- ================= TESTIMONIALS ================= -->
<section class="section bg-cream">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Trusted by the trade</span>
      <h2>What our <span class="accent">partners say</span></h2>
    </div>
    <div class="quotes">
      <figure class="quote">
        <div class="quote__mark">“</div>
        <blockquote><p>Sosun Fihaara keeps our shelves full. Orders arrive on time and the brands move fast — they understand island retail better than anyone.</p></blockquote>
        <figcaption class="quote__who">
          <img class="quote__av" src="/testimonial-ibrahim.svg" alt="Portrait of Ibrahim Naseer" loading="lazy">
          <span><strong>Ibrahim Naseer</strong><span>Owner, Sarusana Store · Addu City</span></span>
        </figcaption>
      </figure>
      <figure class="quote">
        <div class="quote__mark">“</div>
        <blockquote><p>Quality you can trust, every single delivery. Their cold-chain handling means our dairy lines arrive in perfect condition.</p></blockquote>
        <figcaption class="quote__who">
          <img class="quote__av" src="/testimonial-aishath.svg" alt="Portrait of Aishath Reema" loading="lazy">
          <span><strong>Aishath Reema</strong><span>Manager, Shabnamee Store · Laamu</span></span>
        </figcaption>
      </figure>
      <figure class="quote">
        <div class="quote__mark">“</div>
        <blockquote><p>From staple foods to specialty spices, they carry everything our café needs under one supplier. Genuinely a one-stop partner.</p></blockquote>
        <figcaption class="quote__who">
          <img class="quote__av" src="/testimonial-hassan.svg" alt="Portrait of Hassan Waheed" loading="lazy">
          <span><strong>Hassan Waheed</strong><span>Head Chef · Malé</span></span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- ================= CTA BAND ================= -->
<section class="section bg-cream">
  <div class="container">
    <div class="cta-band">
      <h2>Ready to stock the brands your customers want?</h2>
      <p>Tell us what you need and our trade team will put together a tailored wholesale quote — fast.</p>
      <div class="btns">
        <a href="/contact" class="btn btn--gold btn--lg">Get a Quote</a>
        <a href="/brands" class="btn btn--on-dark btn--lg">View Brands</a>
      </div>
    </div>
  </div>
</section>

</main>
</Layout>
