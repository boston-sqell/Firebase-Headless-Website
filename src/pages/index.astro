---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getCmsData, getPromotions, resolveImage } from '../lib/cms';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MagneticButton from '../components/MagneticButton.astro';

let cmsError = false;
let cmsData: any = { products: [], brands: [], site: {} as any, promotions: [] };
try {
  const [data, promotions] = await Promise.all([getCmsData(), getPromotions()]);
  cmsData = { ...data, promotions };
} catch (e) {
  console.error("[homepage] getCmsData failed:", e);
  cmsError = true;
}
const { products, brands, site, promotions } = cmsData;

const heroImage: string = resolveImage(site.homeHeroImage) || '';
const featuredProducts = products.slice(0, 9);
const activeBrands = brands.filter((b: any) => b.active !== false);
---

<HomeLayout title="HOME | Sosun Fihaara">

{cmsError && (
  <div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:12px 24px;text-align:center;font-size:14px;position:relative;z-index:100;">
    ⚠️ Could not load live data — please refresh the page.
  </div>
)}

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[999] focus:text-white focus:px-4 focus:py-2 focus:rounded font-lato font-bold" style="background-color: var(--green);">Skip to main content</a>

<!-- ===== HEADER ===== -->
<Nav />

<div id="main-content">

<!-- ===== HERO ===== -->
<section id="home" class="relative overflow-hidden">
  <div class="relative w-full h-screen min-h-[600px]" style="background: linear-gradient(135deg, #0d2c22 0%, #2a3535 50%, #1a2e1a 100%);">
    {heroImage && (
      <img
        src={heroImage}
        alt="Sosun Fihaara product range"
        class="w-full h-full object-cover object-bottom absolute inset-0"
        fetchpriority="high"
        onerror="this.style.display='none'"
      />
    )}
    <!-- gradient overlays -->
    <div class="absolute inset-x-0 top-0 h-[45%] bg-gradient-to-b from-black via-black/60 to-transparent" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-[50%] bg-gradient-to-t from-[#0d2c22]/90 via-[#0d2c22]/50 to-transparent" aria-hidden="true"></div>
    <!-- Hero content -->
    <div class="absolute bottom-6 left-[2.6vw] right-[8.3vw] pb-[2vw] hero-content-wrapper">
      <div class="hero-stagger-container">
        <p class="tagline-text text-[#c9a96e] mb-2 tracking-[4px] hero-reveal-text">{site.heroTagline || 'Est. 1980 · Maldives FMCG'}</p>
        
        <h1 class="font-alumni text-white font-light leading-[.92] tracking-[-2px] mb-5 hero-title" style="font-size: clamp(64px, 11vw, 160px);">
          <span class="block overflow-hidden"><span class="block hero-title-line">SOSUN</span></span>
          <span class="block overflow-hidden"><span class="block hero-title-line">FIHAARA</span></span>
        </h1>
        
        <p class="font-lato text-white/80 text-[15px] lg:text-[18px] font-light leading-[1.65] mb-6 max-w-xl hero-reveal-text">
          {site.heroSubtext || 'Four decades of trusted FMCG wholesale and retail distribution — delivering quality food and grocery brands across every atoll of the Maldives.'}
        </p>
        
        <div class="flex flex-wrap gap-4 items-center hero-reveal-text">
          <MagneticButton href="/products" className="bg-[#c9a96e] text-[#0d2c22] font-lato text-[13px] font-bold uppercase tracking-[2px] px-8 py-3 rounded-full hover:bg-white transition-colors duration-300">
            Explore Products
          </MagneticButton>
          <MagneticButton href="/contact" className="font-lato text-white text-[14px] font-bold uppercase tracking-[2px] border-b-2 pb-0.5 border-[#c9a96e] hover:text-[#c9a96e] transition-colors">
            Contact Us
          </MagneticButton>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-4 right-4 lg:bottom-6 lg:right-6 flex flex-col items-center gap-1 text-white/50">
      <div class="w-[2px] h-9 border border-white/40 rounded-full flex items-start justify-center pt-1">
        <div class="w-[2px] h-2 bg-white/60 rounded-full scroll-indicator"></div>
      </div>
      <span class="font-lato text-[10px] tracking-[3px] uppercase mt-1">Scroll</span>
    </div>
  </div>
</section>

<!-- ===== PROMOTIONS ===== -->
{promotions.length > 0 && (
<section id="promotions-section" class="mb-20 lg:mb-24 overflow-hidden relative" aria-label="Exclusive promotions">
  <div class="fade-up px-5 lg:px-[8.3vw] pb-10 lg:pb-12 pt-[10vh]">
    <div class="text-center">
      <p class="tagline-text mb-1">Offers Worth Grabbing</p>
      <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">EXCLUSIVE <span class="font-alumni">PROMOTIONS</span></h2>
      <h3 class="sub-title text-[24px] lg:text-[38px] font-light leading-[1.05] tracking-[-0.84px]">You Shouldn't Miss</h3>
    </div>
  </div>
  
  <div class="promo-scroll-container h-screen flex items-center">
    <div class="promo-track flex gap-8 px-[5.2vw] w-max">
      {promotions.map((p: any) => (
        <div class="tilt-card flex-shrink-0 w-[85vw] sm:w-[50vw] lg:w-[35vw] relative rounded-[20px] group cursor-pointer" style="perspective: 1000px; transform-style: preserve-3d;">
          <div class="tilt-inner w-full h-full rounded-[20px] overflow-hidden shadow-2xl relative" style={`min-height:450px; background: ${p.background}; transition: transform 0.1s ease-out;`}>
            <!-- Glassmorphism overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent z-10 pointer-events-none"></div>
            
            <div class="absolute bottom-8 left-8 right-8 z-20" style="transform: translateZ(50px);">
              {p.label && <span class="recipe-featured-tag px-3 py-1.5 text-[12px] tracking-[3px] mb-4 inline-block shadow-md bg-white/20 backdrop-blur-md border border-white/30 text-white">{p.label}</span>}
              <h3 class="font-alumni text-white text-[48px] leading-tight tracking-tight mb-2 drop-shadow-lg">{p.title}</h3>
              {p.subtitle && <p class="font-lato text-white/90 text-[16px] drop-shadow-md max-w-[80%]">{p.subtitle}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- ===== BEST SELLING PRODUCTS ===== -->
<section id="products" class="overflow-hidden pb-20 lg:pb-24" aria-label="Best selling products">
  <div class="px-5 sm:px-8 lg:px-[10.8vw]">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between pb-8 lg:pb-12 gap-6">
      <div class="fade-left">
        <p class="tagline-text mb-1">Most Popular Products</p>
        <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">BEST SELLING <span class="font-alumni">PRODUCTS</span></h2>
      </div>
      <div class="fade-right">
        <MagneticButton href="/products" className="btn-explore">Explore Products</MagneticButton>
      </div>
    </div>
    <div class="fade-up">
      <div class="products-grid-container group/grid">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredProducts.length > 0 ? featuredProducts.map((p: any, i: number) => (
            <div class={`product-card-wrapper transition-all duration-500 hover:z-10 group/grid-hover:opacity-40 hover:!opacity-100 ${i % 2 === 1 ? 'lg:translate-y-12' : ''}`}>
              <article class="product-card relative flex flex-col items-center rounded-[20px] bg-white h-full overflow-hidden shadow-sm hover:shadow-2xl transition-shadow duration-500 transform hover:-translate-y-2">
                <div class="product-img-inner w-full overflow-hidden rounded-t-[20px] relative bg-gradient-to-br from-gray-50 to-gray-200" style="height: clamp(200px, 22vw, 380px);">
                  <div class="absolute inset-0 bg-[#0d2c22]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 pointer-events-none"></div>
                  {p.image ? (
                    <img src={resolveImage(p.image)} alt={p.name} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <span class="font-alumni text-[24px] text-center px-4 leading-tight" style="color: var(--green);">{p.name.split(' ').slice(0,2).join(' ')}</span>
                    </div>
                  )}
                </div>
                <div class="flex flex-col items-center flex-1 px-5 pt-6 pb-10 gap-3 text-center relative z-20">
                  {p.brandName && <p class="font-lato text-[11px] font-semibold uppercase tracking-widest text-[#c9a96e]">{p.brandName}</p>}
                  <h3 class="font-lato font-bold text-[18px] lg:text-[22px] leading-tight text-[#0d2c22]">{p.name}</h3>
                  <div class="mt-auto pt-4">
                    <a href="/products" class="btn-underline text-[#0d2c22] font-semibold" aria-label={`Explore more about ${p.name}`}>Explore More</a>
                  </div>
                </div>
              </article>
            </div>
          )) : (
            [
              { title: "Featured Product", color: "#e8f5e9" },
              { title: "Featured Product", color: "#fff3e0" },
              { title: "Featured Product", color: "#e3f2fd" },
            ].map((ph) => (
              <div class="product-card-wrapper">
                <article class="product-card relative flex flex-col items-center rounded-[20px] border border-[#d3d3d3] bg-[#fefdfb] h-full overflow-hidden">
                  <div class="product-img-inner w-full flex items-center justify-center" style={`height: clamp(200px, 22vw, 380px); background: ${ph.color};`}>
                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--green); opacity: 0.4;" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                  </div>
                  <div class="flex flex-col items-center flex-1 px-5 pt-4 pb-10 gap-4 text-center">
                    <h3 class="font-lato font-bold text-gray-400 text-[16px]">Loading...</h3>
                  </div>
                </article>
              </div>
            ))
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== ABOUT / STATS ===== -->
<section id="about-section" class="relative flow-root pb-20 lg:pb-24" aria-label="About Sosun Fihaara">
  <!-- Background panel -->
  <div class="absolute inset-x-0 top-0 overflow-hidden" style="height: clamp(440px, 75vw, 700px);">
    <div class="w-full h-full" style="background: linear-gradient(135deg, #1a2e1a 0%, #2d5a27 40%, #1e3a1e 100%);"></div>
    {site.partnerImage && (
      <img src={resolveImage(site.partnerImage)} alt="" class="parallax-bg absolute inset-0 w-full h-[120%] object-cover object-center opacity-40 -top-[10%]" loading="lazy" aria-hidden="true" onerror="this.style.display='none'" />
    )}
  </div>
  <div class="relative mx-4 sm:mx-8 lg:mx-[14.9vw] rounded-t-[25px] lg:rounded-t-[3.6vw] bg-[#fefdfb] px-6 lg:px-[5.2vw] pt-16 pb-16 lg:pt-20 lg:pb-20" style="margin-top: clamp(240px, 35vw, 360px);">
    <div class="fade-up text-center mb-12 lg:mb-12">
      <p class="tagline-text mb-2">Who We Are</p>
      <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-4">
        {site.aboutHeading ? site.aboutHeading : (<>BUILT ON <span class="font-alumni">TRUST</span></>)}
      </h2>
      <p class="sub-title text-[18px] lg:text-[24px] font-light leading-[1.4] max-w-2xl mx-auto">{site.aboutSubtext || 'Sosun Fihaara has been the backbone of FMCG distribution in the Maldives since 1980 — supplying retailers, cafés and households across every atoll with trusted international brands.'}</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5 justify-center mb-12" id="stats-container">
      {[
        { num: 40, suffix: "+", label: "Years of Distribution" },
        { num: 25, suffix: "+", label: "International Brands" },
        { num: 300, suffix: "+", label: "Products in Range" },
        { num: 20, suffix: "", label: "Atolls Served" },
      ].map((s) => (
        <div class="text-center border-b-2 pb-4" style="border-color: var(--gold-accent);">
          <p class="font-alumni leading-none tracking-tight flex justify-center items-baseline" style="color: var(--green-house); font-size: clamp(36px, 4vw, 56px);">
            <span class="stat-num" data-target={s.num}>0</span><span>{s.suffix}</span>
          </p>
          <p class="font-lato text-[11px] sm:text-[13px] font-semibold uppercase tracking-[2px] mt-2" style="color: var(--gold-accent);">{s.label}</p>
        </div>
      ))}
    </div>
    <div class="text-center">
      <MagneticButton href="/about" className="btn-explore">Our Story</MagneticButton>
    </div>
  </div>
  <!-- Green marquee ticker -->
  <div class="overflow-hidden py-4 mt-0" style="background: var(--green);" aria-hidden="true">
    <div class="marquee-track flex gap-[10px] whitespace-nowrap">
      <span class="font-alumni text-white text-[24px] tracking-wider">
        {Array(6).fill("WHOLESALE · RETAIL · FMCG · MALDIVES · TRUSTED BRANDS · ISLAND DISTRIBUTION · QUALITY PRODUCTS · ").join("")}
      </span>
    </div>
  </div>
</section>

<!-- ===== BRANDS ===== -->
<section id="brands" class="overflow-hidden pb-20 lg:pb-24" aria-label="Our brand partners">
  <div class="px-5 sm:px-8 lg:px-[9.9vw]">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between pb-8 lg:pb-12 gap-6">
      <div class="fade-left">
        <p class="tagline-text mb-1">Our Trusted Brands</p>
        <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">GLOBAL DISTRIBUTION <span class="font-alumni">BRANDS</span></h2>
        <h3 class="sub-title text-[24px] lg:text-[38px] font-light leading-[1.05] tracking-[-0.84px]">Enabling Seamless Market Access</h3>
      </div>
      <div class="fade-right">
        <MagneticButton href="/brands" className="btn-explore">Explore Brands</MagneticButton>
      </div>
    </div>
  </div>
  
  <div class="fade-up relative w-full overflow-hidden brands-marquee-container group" style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
    <div class="flex w-max brands-marquee-track">
      {[...activeBrands, ...activeBrands, ...activeBrands, ...activeBrands].map((b: any) => (
        <a href={`/brands/${b.slug}`} class="brand-card relative flex-shrink-0 rounded-[16px] border border-[#d3d3d3]/50 bg-white/50 backdrop-blur-sm overflow-hidden cursor-pointer no-underline mx-4 transition-all duration-300 hover:scale-105 hover:bg-white hover:shadow-xl hover:border-[#c9a96e]" style="width: 250px;" aria-label={`Explore ${b.name}`}>
          <div class="flex items-center justify-center p-6 h-[140px]">
            {b.logo ? (
              <img src={resolveImage(b.logo)} alt={`${b.name} logo`} class="w-full h-full object-contain filter grayscale group-hover:grayscale-0 transition-all duration-500 opacity-70 group-hover:opacity-100" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            ) : null}
            <div class={`w-full items-center justify-center font-alumni text-center text-[24px] font-bold${b.logo ? ' hidden' : ' flex'}`} style="color: var(--gold-accent);">{b.name}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ===== RECIPES ===== -->
<section id="recipes" class="mb-16 lg:mb-24" aria-label="Recipes">
  <div class="flex flex-col lg:flex-row px-5 sm:px-8 lg:px-[9.9vw] gap-12 lg:gap-0">
    <div class="lg:w-[38%] lg:pr-[5.2vw]">
      <div class="fade-left mb-8 lg:mb-10">
        <p class="tagline-text mb-1">Recipes Made Simple</p>
        <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">RECIPES <span class="font-alumni">FOR FOOD</span></h2>
        <h3 class="sub-title text-[24px] lg:text-[38px] font-light leading-[1.05] tracking-[-0.84px]">Lovers Like You</h3>
      </div>
      <div class="fade-left">
        <p class="font-lato text-[15px] lg:text-[18px] font-light text-[#0d2c22] leading-[1.65] mb-6">Discover delicious recipes using the authentic brands we distribute — from quick weeknight meals to weekend feasts.</p>
        <a href="/recipes" class="btn-explore">View All Recipes</a>
      </div>
    </div>
    <div class="lg:w-[62%] flex flex-col gap-5">
      {[
        { tag: "FEATURED", title: "Real Thai Pad Thai", sub: "Ready in 20 minutes", bg: "linear-gradient(135deg, #2d5a27, #4a7c3a)", h: "300px" },
        { tag: "QUICK MEAL", title: "Gullon Biscuit Tart", sub: "A crowd-pleasing dessert", bg: "linear-gradient(135deg, #5a3a20, #8c5a30)", h: "200px" },
      ].map((r) => (
        <a href="/recipes" class="relative rounded-[20px] overflow-hidden group block no-underline" style={`height: ${r.h};`}>
          <div class="absolute inset-0" style={`background: ${r.bg};`}></div>
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
          <div class="absolute bottom-5 left-6">
            <span class="recipe-featured-tag px-2 py-1 text-[11px] tracking-[3px] mb-2 inline-block">{r.tag}</span>
            <h3 class="font-alumni text-white text-[28px] leading-tight">{r.title}</h3>
            <p class="font-lato text-white/80 text-sm">{r.sub}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ===== INSTAGRAM ===== -->
<section class="px-5 sm:px-8 lg:px-[8.3vw] pb-16 lg:pb-24" aria-label="Follow us on Instagram">
  <div class="fade-up flex items-center justify-center gap-3 mb-6 lg:mb-8">
    <div class="w-11 h-11 rounded-full overflow-hidden border-2 flex items-center justify-center flex-shrink-0" style="border-color: var(--gold-accent); background: var(--gold-accent);">
      <span class="font-alumni text-white font-bold text-lg">SF</span>
    </div>
    <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" class="font-alumni text-[24px] font-semibold tracking-wide no-underline transition-colors nav-insta" style="color: var(--green-house);">@sosun.fihaara</a>
  </div>
  <div class="fade-up grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
    {[
      { bg: "linear-gradient(135deg, #2d5a27, #4a8c40)", label: "Post 1" },
      { bg: "linear-gradient(135deg, #5a3a20, #8c5a30)", label: "Post 2" },
      { bg: "linear-gradient(135deg, #1e3a5a, #2a5a8c)", label: "Post 3" },
      { bg: "linear-gradient(135deg, #4a2d5a, #7a4a8c)", label: "Post 4" },
      { bg: "linear-gradient(135deg, #5a5a20, #8c8c30)", label: "Post 5" },
      { bg: "linear-gradient(135deg, #2d3a5a, #3a5a8c)", label: "Post 6" },
    ].map((post, i) => (
      <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" class="relative overflow-hidden rounded-[7px] group block no-underline" style="aspect-ratio: 1;" aria-label={`Instagram post ${i + 1}`}>
        <div class="absolute inset-0 group-hover:scale-110 transition-transform duration-500" style={`background: ${post.bg};`}></div>
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" opacity="0.4"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none"/></svg>
        </div>
      </a>
    ))}
  </div>
  <div class="text-center">
    <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" class="btn-explore">Follow on Instagram</a>
  </div>
</section>

</div><!-- /main-content -->

<!-- ===== FOOTER ===== -->
<Footer />

<!-- ===== SCRIPTS ===== -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAnimations() {
    // 1. Hero Reveal Animation
    const heroTl = gsap.timeline({ defaults: { ease: "power4.out" } });
    
    // Initial state
    gsap.set('.hero-title-line', { yPercent: 100 });
    gsap.set('.hero-reveal-text', { autoAlpha: 0, y: 20 });
    
    heroTl.to('.hero-title-line', {
      yPercent: 0,
      duration: 1.2,
      stagger: 0.15,
      delay: 0.2
    })
    .to('.hero-reveal-text', {
      autoAlpha: 1,
      y: 0,
      duration: 1,
      stagger: 0.1
    }, "-=0.8");

    // 2. Generic Scroll Reveal (replacing IO)
    gsap.utils.toArray('.fade-up').forEach((el: any) => {
      gsap.fromTo(el, 
        { autoAlpha: 0, y: 40 },
        { 
          autoAlpha: 1, y: 0, duration: 1, ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 85%" }
        }
      );
    });

    gsap.utils.toArray('.fade-left').forEach((el: any) => {
      gsap.fromTo(el, 
        { autoAlpha: 0, x: -40 },
        { 
          autoAlpha: 1, x: 0, duration: 1, ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 85%" }
        }
      );
    });

    gsap.utils.toArray('.fade-right').forEach((el: any) => {
      gsap.fromTo(el, 
        { autoAlpha: 0, x: 40 },
        { 
          autoAlpha: 1, x: 0, duration: 1, ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 85%" }
        }
      );
    });

    // 3. Pinned Horizontal Scroll for Promotions
    const promoSection = document.querySelector('#promotions-section');
    const promoTrack = document.querySelector('.promo-track');
    
    if (promoSection && promoTrack) {
      const scrollAmount = promoTrack.scrollWidth - window.innerWidth;
      
      gsap.to(promoTrack, {
        x: -scrollAmount,
        ease: "none",
        scrollTrigger: {
          trigger: promoSection,
          start: "top top",
          end: `+=${scrollAmount}`,
          pin: true,
          scrub: 1,
          invalidateOnRefresh: true,
        }
      });
    }

    // 4. 3D Tilt Cards Logic
    const tiltCards = document.querySelectorAll('.tilt-card');
    tiltCards.forEach(card => {
      const inner = card.querySelector('.tilt-inner') as HTMLElement;
      if (!inner) return;

      card.addEventListener('mousemove', (e: any) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = ((y - centerY) / centerY) * -10;
        const rotateY = ((x - centerX) / centerX) * 10;
        
        gsap.to(inner, {
          rotateX,
          rotateY,
          duration: 0.5,
          ease: "power2.out"
        });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(inner, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.8,
          ease: "elastic.out(1, 0.3)"
        });
      });
    });

    // 5. Parallax Background & Stats Counter
    const parallaxBg = document.querySelector('.parallax-bg');
    if (parallaxBg) {
      gsap.to(parallaxBg, {
        yPercent: 20,
        ease: "none",
        scrollTrigger: {
          trigger: '#about-section',
          start: "top bottom",
          end: "bottom top",
          scrub: true
        }
      });
    }

    const statsContainer = document.querySelector('#stats-container');
    if (statsContainer) {
      const nums = document.querySelectorAll('.stat-num');
      ScrollTrigger.create({
        trigger: statsContainer,
        start: "top 80%",
        once: true,
        onEnter: () => {
          nums.forEach(num => {
            const target = parseFloat(num.getAttribute('data-target') || '0');
            gsap.to(num, {
              innerHTML: target,
              duration: 2.5,
              ease: "power2.out",
              snap: { innerHTML: 1 },
              onUpdate: function() {
                num.innerHTML = Math.round(this.targets()[0].innerHTML).toString();
              }
            });
          });
        }
      });
    }

    // 6. Infinite Brands Marquee
    const brandsTrack = document.querySelector('.brands-marquee-track');
    const brandsContainer = document.querySelector('.brands-marquee-container');
    
    if (brandsTrack && brandsContainer) {
      // Create a seamless loop using GSAP horizontal modifier
      const marqueeTween = gsap.to(brandsTrack, {
        xPercent: -50, // scroll half the duplicated track
        ease: "none",
        duration: 30, // speed
        repeat: -1
      });
      
      // Pause on hover
      brandsContainer.addEventListener('mouseenter', () => marqueeTween.pause());
      brandsContainer.addEventListener('mouseleave', () => marqueeTween.play());
    }
  }

  // Handle initialization on page load and View Transitions
  document.addEventListener('astro:page-load', initAnimations);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initAnimations();
  } else {
    window.addEventListener('DOMContentLoaded', initAnimations);
  }
</script>

</HomeLayout>
