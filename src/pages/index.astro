---
// index.astro - B2B Reframed Homepage
import HomeLayout from '../layouts/HomeLayout.astro';
import { getProducts, getBrands, getSiteContent, getRecipes, getNews, resolveImage } from '../lib/cms';
import type { Product, Brand, Recipe, NewsItem, SiteContent } from '../lib/cms';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

let cmsError = false;
let cmsData = {
  products: [] as Product[],
  brands: [] as Brand[],
  site: {} as SiteContent,
  recipes: [] as Recipe[],
  news: [] as NewsItem[]
};

try {
  const [products, brands, site, recipes, news] = await Promise.all([
    getProducts(),
    getBrands(),
    getSiteContent(),
    getRecipes(),
    getNews()
  ]);
  cmsData = { products, brands, site, recipes, news };
} catch (e) {
  console.error("[homepage] getCmsData failed:", e);
  cmsError = true;
}

const { products, brands, recipes, news } = cmsData;
console.log("[index] products count:", products.length);
console.log("[index] brands count:", brands.length);
console.log("[index] recipes count:", recipes.length);
console.log("[index] news count:", news.length);
console.log("[index] cmsError status:", cmsError);

// Fallback background hero image if not in database
const heroImage = '/images/hero_distribution.png';

// B2B Catalog Filtering: 8 products maximum
const featuredProducts = products.filter(p => p.active !== false).slice(0, 8);

// Brands: 12 brands initially for the B2B portfolio grid
const activeBrands = brands.filter(b => b.active !== false);
const uniqueActiveBrands = activeBrands.filter((brand: Brand, index: number, list: Brand[]) => {
  const key = brand.slug || brand.name;
  return list.findIndex((candidate: Brand) => (candidate.slug || candidate.name) === key) === index;
});
const initialBrands = uniqueActiveBrands.slice(0, 12);

// Insights queries: limit 3
const activeRecipes = recipes.filter(r => r.active !== false).slice(0, 3);
const activeNews = news.filter(n => n.active !== false).slice(0, 3);
---

<HomeLayout title="Global essentials. Delivered across the Maldives. | Sosun Fihaara" preloadImage={heroImage}>

  {cmsError && (
    <div role="alert" style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:12px 24px;text-align:center;font-size:14px;position:relative;z-index:100;">
      ⚠️ Could not load live data — please refresh the page.
    </div>
  )}

  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[999] focus:text-white focus:px-4 focus:py-2 focus:rounded font-body font-bold" style="background-color: var(--color-green);">Skip to main content</a>

  <!-- ===== 1. HEADER ===== -->
  <Nav />

  <main id="main-content" class="bg-[#F6F2E8]">

    <!-- ===== 2. HERO: “Distribution, shaped by the islands” ===== -->
    <section id="hero" class="relative overflow-hidden flex items-center pt-20" style="height: clamp(650px, 88vh, 1000px); background: #083C2B;">
      <div class="absolute inset-0 w-full h-full">
        <img
          src={heroImage}
          alt="Sosun Fihaara marine distribution supply line boat delivering cargo across Maldivian lagoons"
          class="w-full h-full object-cover object-center opacity-40 absolute inset-0"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#083C2B] via-[#083C2B]/60 to-transparent" aria-hidden="true"></div>
      </div>
      
      <div class="relative w-full max-w-[1320px] mx-auto px-5 lg:px-10 z-10">
        <div class="max-w-3xl hero-content-wrapper text-white reveal">
          <p class="text-[#C5A578] font-body text-xs font-bold uppercase tracking-[4px] mb-3">Maldives FMCG Distribution · Established 1980</p>
          <h1 class="font-display font-bold text-white leading-[1.05] tracking-tight mb-6" style="font-size: var(--type-h1);">
            Global essentials.<br />
            Delivered across the Maldives.
          </h1>
          <p class="font-body text-[#DDEBE2]/90 text-[16px] lg:text-[18px] leading-[1.6] mb-8 max-w-2xl">
            Trusted wholesale and retail distribution for international brands, island retailers, resorts, cafés, and households. Supporting local commerce with absolute operational precision.
          </p>
          
          <div class="flex flex-wrap gap-4 items-center mb-12">
            <a href="/request-quote" class="btn-primary">
              Request a Wholesale Quote
            </a>
            <a href="/products" class="btn-secondary">
              Explore Products
            </a>
          </div>
        </div>

        <!-- Credibility Rail -->
        <div class="border-t border-[#D8D4C9]/20 pt-6 mt-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-white reveal">
          <div>
            <span class="block font-display font-bold text-2xl lg:text-3xl text-[#C5A578]">40+ Years</span>
            <span class="block font-body text-xs uppercase tracking-wider text-[#DDEBE2]/60 mt-1">Operational Credibility</span>
          </div>
          <div>
            <span class="block font-display font-bold text-2xl lg:text-3xl text-[#C5A578]">20 Atolls</span>
            <span class="block font-body text-xs uppercase tracking-wider text-[#DDEBE2]/60 mt-1">Served Nationwide</span>
          </div>
          <div>
            <span class="block font-display font-bold text-2xl lg:text-3xl text-[#C5A578]">25+ Brands</span>
            <span class="block font-body text-xs uppercase tracking-wider text-[#DDEBE2]/60 mt-1">Distributed Exclusively</span>
          </div>
          <div>
            <span class="block font-display font-bold text-2xl lg:text-3xl text-[#C5A578]">300+ Products</span>
            <span class="block font-body text-xs uppercase tracking-wider text-[#DDEBE2]/60 mt-1">Active Catalogue</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 3. AUDIENCE GATEWAY ===== -->
    <section class="py-20 bg-[#F6F2E8]">
      <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
        <div class="text-center mb-12 reveal">
          <p class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-2">Tailored Procurement Pathways</p>
          <h2 class="font-display font-bold text-[#18231D]" style="font-size: var(--type-h3);">Can we serve your business?</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Gateway 1 -->
          <article class="bg-white border border-[#D8D4C9] rounded-2xl overflow-hidden flex flex-col justify-between hover:shadow-lg transition-shadow duration-300 reveal">
            <div class="aspect-[16/10] overflow-hidden bg-[#EAE6DC]">
              <img src="/images/retail_supply.png" alt="Maldivian retail grocery shop shelf stocked with products" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <h3 class="font-display font-bold text-xl text-[#18231D] mb-2">Retailers & Shops</h3>
                <p class="font-body text-sm text-[#566159] leading-relaxed mb-6">Keep your shelves stocked with global brands Maldivians trust.</p>
              </div>
              <a href="/distribution/retail-supply" class="text-sm font-bold text-[#00663B] hover:text-[#083C2B] inline-flex items-center gap-2 no-underline">
                Explore Retail Supply <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>

          <!-- Gateway 2 -->
          <article class="bg-white border border-[#D8D4C9] rounded-2xl overflow-hidden flex flex-col justify-between hover:shadow-lg transition-shadow duration-300 reveal">
            <div class="aspect-[16/10] overflow-hidden bg-[#EAE6DC]">
              <img src="/images/hospitality_supply.png" alt="Chef preparing fresh meal at a luxury Maldivian island resort" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <h3 class="font-display font-bold text-xl text-[#18231D] mb-2">Hospitality & Food Service</h3>
                <p class="font-body text-sm text-[#566159] leading-relaxed mb-6">Reliable ingredients and supply lines for resorts, cafés, and kitchens.</p>
              </div>
              <a href="/distribution/hospitality-food-service" class="text-sm font-bold text-[#00663B] hover:text-[#083C2B] inline-flex items-center gap-2 no-underline">
                Explore Hospitality Supply <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>

          <!-- Gateway 3 -->
          <article class="bg-white border border-[#D8D4C9] rounded-2xl overflow-hidden flex flex-col justify-between hover:shadow-lg transition-shadow duration-300 reveal">
            <div class="aspect-[16/10] overflow-hidden bg-[#EAE6DC]">
              <img src="/images/brand_partnerships.png" alt="Clean modern distribution shipping dock and logistics warehouse operations" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div>
                <h3 class="font-display font-bold text-xl text-[#18231D] mb-2">Global Brand Partners</h3>
                <p class="font-body text-sm text-[#566159] leading-relaxed mb-6">Your bridge to the Maldivian market, built on four decades of logistics expertise.</p>
              </div>
              <a href="/distribution/brand-partnerships" class="text-sm font-bold text-[#00663B] hover:text-[#083C2B] inline-flex items-center gap-2 no-underline">
                Explore Brand Partnerships <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== 4. DISTRIBUTION SIGNATURE ===== -->
    <section class="py-20 bg-white border-y border-[#D8D4C9]/40">
      <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="reveal">
            <p class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-2">Operational Precision</p>
            <h2 class="font-display font-bold text-[#18231D] leading-tight mb-6" style="font-size: var(--type-h2);">
              Nationwide reach,<br />shaped by the islands.
            </h2>
            <p class="font-body text-base text-[#566159] leading-relaxed mb-8">
              Moving fast-moving consumer goods across an archipelagic nation requires specialized logistics. From our main operational base in Malé, Sosun Fihaara delivers consistent inventory to over 180 islands. Utilizing sea-cargo routes, temperature-controlled cargo, and dedicated local warehouses, we bridge global brands with communities in all 20 atolls.
            </p>

            <div class="grid grid-cols-2 gap-6 mb-8 text-[#18231D]">
              <div class="border-l-2 border-[#C5A578] pl-4">
                <span class="block text-xs uppercase tracking-wider text-[#566159] font-bold">Logistics Hub</span>
                <span class="block font-display font-bold text-lg mt-1">Malé Port Base</span>
              </div>
              <div class="border-l-2 border-[#C5A578] pl-4">
                <span class="block text-xs uppercase tracking-wider text-[#566159] font-bold">Atoll Coverage</span>
                <span class="block font-display font-bold text-lg mt-1">20 / 20 Atolls</span>
              </div>
              <div class="border-l-2 border-[#C5A578] pl-4">
                <span class="block text-xs uppercase tracking-wider text-[#566159] font-bold">Delivery Channels</span>
                <span class="block font-display font-bold text-lg mt-1">Dry & Cold Chain</span>
              </div>
              <div class="border-l-2 border-[#C5A578] pl-4">
                <span class="block text-xs uppercase tracking-wider text-[#566159] font-bold">Partner Outlets</span>
                <span class="block font-display font-bold text-lg mt-1">180+ Inhabited Islands</span>
              </div>
            </div>

            <a href="/about/distribution-network" class="btn-primary inline-flex">
              Explore Our Distribution Network
            </a>
          </div>

          <!-- Abstract SVG Map -->
          <div class="relative atoll-map flex justify-center py-6 bg-[#F6F2E8] rounded-2xl border border-[#D8D4C9]" aria-hidden="true">
            <svg viewBox="0 0 540 760" class="w-full max-w-[420px] h-auto drop-shadow-sm">
              <defs>
                <linearGradient id="routeGradient" x1="0" y1="0" x2="0" y2="1">
                  <stop stop-color="#C5A578"/>
                  <stop offset="1" stop-color="#00663B"/>
                </linearGradient>
              </defs>
              <path class="atoll-route" pathLength="1" d="M284 38 C340 120 198 168 278 242 S344 340 243 410 S360 520 269 600 S220 680 286 730" fill="none" stroke="url(#routeGradient)" stroke-width="2.5" stroke-linecap="round" />
              {[{x:286,y:50},{x:324,y:97},{x:244,y:145},{x:214,y:196},{x:287,y:244},{x:320,y:294},{x:270,y:342},{x:230,y:393},{x:260,y:443},{x:315,y:482},{x:337,y:527},{x:276,y:570},{x:242,y:616},{x:215,y:662},{x:281,y:718}].map((dot, i) => (
                <g class="atoll-node">
                  <circle cx={dot.x} cy={dot.y} r={i === 8 ? 10 : 6} fill="#00663B" fill-opacity="0.15" class="animate-ping" style={`animation-delay: ${i * 0.1}s; animation-duration: 3s;`} />
                  <circle cx={dot.x} cy={dot.y} r={i === 8 ? 5 : 3} fill={i === 8 ? "#C5A578" : "#00663B"} />
                </g>
              ))}
              <text x="285" y="465" font-family="var(--font-display)" font-size="12" font-weight="bold" fill="#083C2B" letter-spacing="2" text-anchor="middle">MALÉ HUB</text>
            </svg>
            <div class="sr-only">
              Visual map illustrating maritime logistics paths from Malé Hub out to north, central, and south atolls of the Maldives.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 5. FEATURED PRODUCT RANGE ===== -->
    <section class="py-20 bg-[#F6F2E8]" id="featured-products">
      <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-12 gap-6 reveal">
          <div class="max-w-lg">
            <p class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-2">Curated Assortment</p>
            <h2 class="font-display font-bold text-[#18231D] leading-tight" style="font-size: var(--type-h2);">Featured Products</h2>
          </div>

          <!-- Product Filters (Client-side) -->
          <div class="flex flex-wrap gap-2 font-body text-sm">
            <button class="filter-btn active" data-category="all">All</button>
            <button class="filter-btn" data-category="Confectionery">Confectionery</button>
            <button class="filter-btn" data-category="Beverages">Beverages</button>
            <button class="filter-btn" data-category="Pantry">Pantry Staples</button>
            <button class="filter-btn" data-category="Household">Household</button>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12" id="homepage-products-grid">
          {featuredProducts.map(p => (
            <article class="bg-white border border-[#D8D4C9] rounded-xl overflow-hidden flex flex-col h-full hover:shadow-lg transition-all duration-300 reveal" data-category={p.category}>
              <div class="aspect-[4/3] w-full overflow-hidden bg-[#F6F2E8] border-b border-[#D8D4C9] relative flex items-center justify-center">
                <img src={resolveImage(p.image)} alt={p.name} class="w-full h-full object-cover hover:scale-103 transition-transform duration-300" loading="lazy" />
              </div>
              <div class="p-5 flex flex-col flex-grow">
                <span class="text-[11px] font-bold uppercase tracking-wider text-[#C5A578] font-body block mb-1">{p.brandName}</span>
                <h3 class="font-display font-bold text-base text-[#18231D] leading-tight mb-2 flex-grow">{p.name}</h3>
                <div class="mt-auto pt-3 border-t border-[#D8D4C9]/40 flex flex-col gap-2">
                  <div class="flex justify-between items-center text-xs font-body text-[#566159]">
                    <span>Pack: {p.packSize || 'Standard'}</span>
                    <span>{p.category}</span>
                  </div>
                  <div class="flex items-center justify-between mt-1">
                    <span class="font-display font-bold text-sm text-[#00663B]">
                      {p.price ? `MVR ${p.price}` : 'Wholesale enquiry'}
                    </span>
                    <a href={`/products/${p.code}`} class="text-xs font-bold text-[#00663B] hover:text-[#083C2B] no-underline inline-flex items-center gap-1">
                      View details <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center reveal">
          <a href="/products" class="btn-secondary inline-flex">
            View Complete Catalogue
          </a>
        </div>
      </div>
    </section>

    <!-- ===== 6. COMMERCIAL PROOF (DEEP GREEN) ===== -->
    <section class="py-20 text-white bg-[#083C2B]">
      <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
        <div class="text-center max-w-3xl mx-auto mb-16 reveal">
          <p class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-2">Proven Track Record</p>
          <h2 class="font-display font-bold text-white leading-tight" style="font-size: var(--type-h2);">
            A distribution partner built for island markets.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-20">
          <div class="bg-[#0d2c22]/50 border border-[#D8D4C9]/10 p-6 rounded-xl reveal">
            <span class="block font-display font-bold text-4xl text-[#C5A578] mb-2">40+ Yrs</span>
            <h3 class="text-sm font-bold font-body uppercase text-white mb-2">Established History</h3>
            <p class="text-[#DDEBE2]/75 text-sm font-body leading-relaxed">Continuous logistics operations in Malé and across atolls since 1980.</p>
          </div>

          <div class="bg-[#0d2c22]/50 border border-[#D8D4C9]/10 p-6 rounded-xl reveal">
            <span class="block font-display font-bold text-4xl text-[#C5A578] mb-2">100%</span>
            <h3 class="text-sm font-bold font-body uppercase text-white mb-2">Authentic Imports</h3>
            <p class="text-[#DDEBE2]/75 text-sm font-body leading-relaxed">Direct partner relationships ensuring original packaging and cold chain integrity.</p>
          </div>

          <div class="bg-[#0d2c22]/50 border border-[#D8D4C9]/10 p-6 rounded-xl reveal">
            <span class="block font-display font-bold text-4xl text-[#C5A578] mb-2">300+</span>
            <h3 class="text-sm font-bold font-body uppercase text-white mb-2">Stocked Lines</h3>
            <p class="text-[#DDEBE2]/75 text-sm font-body leading-relaxed">Curated inventory across confectionery, beverages, pantry staples, and detergents.</p>
          </div>

          <div class="bg-[#0d2c22]/50 border border-[#D8D4C9]/10 p-6 rounded-xl reveal">
            <span class="block font-display font-bold text-4xl text-[#C5A578] mb-2">180+</span>
            <h3 class="text-sm font-bold font-body uppercase text-white mb-2">Islands Supplied</h3>
            <p class="text-[#DDEBE2]/75 text-sm font-body leading-relaxed">B2B sea-ferry delivery channels supporting regional merchants nationwide.</p>
          </div>
        </div>

        <!-- Testimonials -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <div class="bg-white/5 border border-white/10 p-8 rounded-xl flex flex-col justify-between reveal">
            <p class="text-base text-[#DDEBE2]/90 italic font-body leading-relaxed mb-6">
              "Sosun Fihaara has been our primary supply partner for over a decade. Their delivery logistics to our Baa Atoll resort is consistently punctual, and the cold-chain storage maintains product quality perfectly."
            </p>
            <div class="flex items-center gap-3">
              <img src="/testimonial-hassan.svg" alt="Hassan Rasheed icon" class="w-10 h-10 rounded-full" />
              <div>
                <span class="block font-bold text-sm">Hassan Rasheed</span>
                <span class="block text-xs text-[#DDEBE2]/50">F&B Director, Seaside Resorts Group (Baa Atoll)</span>
              </div>
            </div>
          </div>

          <div class="bg-white/5 border border-white/10 p-8 rounded-xl flex flex-col justify-between reveal">
            <p class="text-base text-[#DDEBE2]/90 italic font-body leading-relaxed mb-6">
              "For local retailers like us in Malé, stock consistency is everything. Sosun Fihaara keeps our inventory full of the global brands our customers ask for, backed by clear wholesale terms."
            </p>
            <div class="flex items-center gap-3">
              <img src="/testimonial-ibrahim.svg" alt="Ibrahim Sameer icon" class="w-10 h-10 rounded-full" />
              <div>
                <span class="block font-bold text-sm">Ibrahim Sameer</span>
                <span class="block text-xs text-[#DDEBE2]/50">General Manager, Island Grocers Ltd (Malé)</span>
              </div>
            </div>
          </div>

          <div class="bg-white/5 border border-white/10 p-8 rounded-xl flex flex-col justify-between reveal">
            <p class="text-base text-[#DDEBE2]/90 italic font-body leading-relaxed mb-6">
              "Their direct-import confectionery range has allowed my bakery business to maintain premium standards. Quote requests are processed within a business day, making our order planning simple."
            </p>
            <div class="flex items-center gap-3">
              <img src="/testimonial-aishath.svg" alt="Aishath Shifa icon" class="w-10 h-10 rounded-full" />
              <div>
                <span class="block font-bold text-sm">Aishath Shifa</span>
                <span class="block text-xs text-[#DDEBE2]/50">Owner, Shifa Bakery & Cafe (Hulhumalé)</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 7. BRAND PORTFOLIO ===== -->
    <section class="py-20 bg-white" id="brand-portfolio">
      <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
        <div class="text-center max-w-2xl mx-auto mb-12 reveal">
          <p class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body mb-2">Global Partnerships</p>
          <h2 class="font-display font-bold text-[#18231D]" style="font-size: var(--type-h3);">Exclusively Distributed Brands</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
          {initialBrands.map(b => (
            <article class="bg-[#F6F2E8] border border-[#D8D4C9] rounded-xl p-6 flex flex-col items-center justify-center text-center h-[140px] hover:shadow-md hover:border-[#C5A578] transition-all duration-300 reveal">
              {b.logo ? (
                <img src={resolveImage(b.logo)} alt={`${b.name} brand logo`} class="h-10 max-w-[80%] object-contain mb-3" />
              ) : null}
              <span class="font-display font-bold text-base text-[#18231D]">{b.name}</span>
              <a href={`/brands/${b.slug}`} class="text-[11px] font-bold uppercase tracking-wider text-[#00663B] no-underline mt-2 inline-flex items-center gap-1">
                Explore brand <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </a>
            </article>
          ))}
        </div>

        <div class="text-center reveal">
          <a href="/brands" class="btn-secondary inline-flex">
            View All Brands
          </a>
        </div>
      </div>
    </section>

    <!-- ===== 8. HERITAGE STORY ===== -->
    <section class="py-20 bg-[#F6F2E8]">
