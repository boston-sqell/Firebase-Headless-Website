<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHomepage() {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) {
      gsap.set('.reveal, .atoll-route', { clearProps: 'all', opacity: 1, y: 0 });
      return;
    }

    // 1. Scroll reveal triggers once
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      gsap.fromTo(el, 
        { opacity: 0, y: 24 },
        { 
          opacity: 1, 
          y: 0, 
          duration: 0.45, 
          ease: "power2.out",
          scrollTrigger: {
            trigger: el,
            start: "top 85%",
            toggleActions: "play none none none"
          }
        }
      );
    });

    // 2. Draw SVG Maldives route path once
    const route = document.querySelector('.atoll-route');
    if (route) {
      const length = (route as SVGPathElement).getTotalLength();
      gsap.set(route, { strokeDasharray: length, strokeDashoffset: length });
      gsap.to(route, {
        strokeDashoffset: 0,
        duration: 1.1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: '.atoll-map',
          start: "top 75%",
          toggleActions: "play none none none"
        }
      });
    }

    // 3. Client-side Featured Catalog Filtering
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('#homepage-products-grid article');
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.getAttribute('data-category');
        
        cards.forEach((card: any) => {
          if (cat === 'all' || card.getAttribute('data-category') === cat) {
            card.style.display = 'flex';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });

    document.addEventListener('astro:before-swap', () => {
      ScrollTrigger.getAll().forEach(trigger => trigger.kill());
    });
  }

  document.addEventListener('astro:page-load', initHomepage);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initHomepage();
  } else {
    window.addEventListener('DOMContentLoaded', initHomepage);
  }
</script>
