---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getCmsData, getPromotions, resolveImage } from '../lib/cms';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

let cmsError = false;
let cmsData: any = { products: [], brands: [], site: {} as any, promotions: [] };
try {
  const [data, promotions] = await Promise.all([getCmsData(), getPromotions()]);
  cmsData = { ...data, promotions };
} catch (e) {
  console.error("[homepage] getCmsData failed:", e);
  cmsError = true;
}
const { products, brands, site, promotions } = cmsData;

const heroImage: string = resolveImage(site.homeHeroImage) || '';
const featuredProducts = products.slice(0, 9);
const activeBrands = brands.filter((b: any) => b.active !== false);
---

<HomeLayout title="HOME | Sosun Fihaara">

{cmsError && (
  <div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:12px 24px;text-align:center;font-size:14px;position:relative;z-index:100;">
    ⚠️ Could not load live data — please refresh the page.
  </div>
)}

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[999] focus:text-white focus:px-4 focus:py-2 focus:rounded font-lato font-bold" style="background-color: var(--green);">Skip to main content</a>

<!-- ===== HEADER ===== -->
<Nav />

<div id="main-content">

<!-- ===== HERO ===== -->
<section id="home" class="relative overflow-hidden">
  <div class="relative w-full h-screen min-h-[600px]" style="background: linear-gradient(135deg, #0d2c22 0%, #2a3535 50%, #1a2e1a 100%);">
    {heroImage && (
      <img
        src={heroImage}
        alt="Sosun Fihaara product range"
        class="w-full h-full object-cover object-bottom absolute inset-0"
        fetchpriority="high"
        onerror="this.style.display='none'"
      />
    )}
    <!-- gradient overlays -->
    <div class="absolute inset-x-0 top-0 h-[45%] bg-gradient-to-b from-black via-black/60 to-transparent" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-[50%] bg-gradient-to-t from-black/90 via-black/50 to-transparent" aria-hidden="true"></div>
    <!-- Hero content -->
    <div class="absolute bottom-6 left-[2.6vw] right-[8.3vw] pb-[2vw]">
      <div class="fade-up">
        <p class="tagline-text text-[#c9a96e] mb-2 tracking-[4px]">{site.heroTagline || 'Est. 1980 · Maldives FMCG'}</p>
        <h1 class="font-alumni text-white font-light leading-[.92] tracking-[-2px] mb-5" style="font-size: clamp(64px, 11vw, 160px);">SOSUN<br />FIHAARA</h1>
        <p class="font-lato text-white/80 text-[15px] lg:text-[18px] font-light leading-[1.65] mb-6 max-w-xl">{site.heroSubtext || 'Four decades of trusted FMCG wholesale and retail distribution — delivering quality food and grocery brands across every atoll of the Maldives.'}</p>
        <div class="flex flex-wrap gap-4 items-center">
          <a href="/products" class="btn-explore">Explore Products</a>
          <a href="/contact" class="font-lato text-white text-[14px] font-bold uppercase tracking-[2px] border-b-2 pb-0.5 no-underline transition-colors nav-contact" style="border-color: var(--gold-accent);">Contact Us</a>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-4 right-4 lg:bottom-6 lg:right-6 flex flex-col items-center gap-1 text-white/50">
      <div class="w-[2px] h-9 border border-white/40 rounded-full flex items-start justify-center pt-1">
        <div class="w-[2px] h-2 bg-white/60 rounded-full scroll-indicator"></div>
      </div>
      <span class="font-lato text-[10px] tracking-[3px] uppercase mt-1">Scroll</span>
    </div>
  </div>
</section>

<!-- ===== PROMOTIONS ===== -->
{promotions.length > 0 && (
<section class="mb-20 lg:mb-24" aria-label="Exclusive promotions">
  <div class="fade-up px-5 lg:px-[8.3vw] pb-10 lg:pb-12">
    <div class="text-center">
      <p class="tagline-text mb-1">Offers Worth Grabbing</p>
      <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">EXCLUSIVE <span class="font-alumni">PROMOTIONS</span></h2>
      <h3 class="sub-title text-[24px] lg:text-[38px] font-light leading-[1.05] tracking-[-0.84px]">You Shouldn't Miss</h3>
    </div>
  </div>
  <div class="fade-up px-5 sm:px-8 lg:px-[5.2vw]">
    <div class="flex gap-4 overflow-hidden">
      {promotions.map((p: any) => (
        <div class="flex-shrink-0 w-full sm:w-[48%] lg:w-[31%] relative rounded-[20px] overflow-hidden group cursor-pointer" style={`min-height:340px; background: ${p.background};`}>
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
          <div class="absolute bottom-6 left-6 right-6">
            {p.label && <span class="recipe-featured-tag px-2 py-1 text-[11px] tracking-[3px] mb-3 inline-block">{p.label}</span>}
            <h3 class="font-alumni text-white text-[32px] leading-tight tracking-tight mb-1">{p.title}</h3>
            {p.subtitle && <p class="font-lato text-white/80 text-sm">{p.subtitle}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- ===== BEST SELLING PRODUCTS ===== -->
<section id="products" class="overflow-hidden pb-20 lg:pb-24" aria-label="Best selling products">
  <div class="px-5 sm:px-8 lg:px-[10.8vw]">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between pb-8 lg:pb-12 gap-6">
      <div class="fade-left">
        <p class="tagline-text mb-1">Most Popular Products</p>
        <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">BEST SELLING <span class="font-alumni">PRODUCTS</span></h2>
      </div>
      <div class="fade-right">
        <a href="/products" class="btn-explore">Explore Products</a>
      </div>
    </div>
    <div class="fade-up">
      <div class="relative">
        <div class="overflow-hidden">
          <div class="flex ease-in-out" id="products-track" role="region" aria-label="Products" style="gap: 8px; transition: transform 0.5s ease;">
            {featuredProducts.length > 0 ? featuredProducts.map((p: any) => (
              <div class="flex-shrink-0" style="width: calc(33.3333% - 5.33333px);">
                <article class="product-card relative flex flex-col items-center rounded-[20px] border border-[#d3d3d3] bg-[#fefdfb] h-full overflow-hidden">
                  <div class="product-img-inner w-full overflow-hidden rounded-t-[20px]" style="height: clamp(160px, 18.85vw, 340px);">
                    {p.image ? (
                      <img src={resolveImage(p.image)} alt={p.name} class="w-full h-full object-cover transition-transform duration-500" loading="lazy" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, #e8f5e9, #c8e6c9);">
                        <span class="font-alumni text-[24px] text-center px-4 leading-tight" style="color: var(--green);">{p.name.split(' ').slice(0,2).join(' ')}</span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-col items-center flex-1 px-5 pt-4 pb-10 gap-2 text-center">
                    {p.brandName && <p class="font-lato text-[11px] font-semibold uppercase tracking-widest" style="color: var(--gold-accent);">{p.brandName}</p>}
                    <h3 class="font-lato font-bold text-[16px] lg:text-[20px] leading-tight" style="color: var(--green-house);">{p.name}</h3>
                    <div class="mt-auto">
                      <a href="/products" class="btn-underline" aria-label={`Explore more about ${p.name}`}>Explore More</a>
                    </div>
                  </div>
                </article>
              </div>
            )) : (
              [
                { title: "Featured Product", color: "#e8f5e9" },
                { title: "Featured Product", color: "#fff3e0" },
                { title: "Featured Product", color: "#e3f2fd" },
              ].map((ph) => (
                <div class="flex-shrink-0" style="width: calc(33.3333% - 5.33333px);">
                  <article class="product-card relative flex flex-col items-center rounded-[20px] border border-[#d3d3d3] bg-[#fefdfb] h-full overflow-hidden">
                    <div class="product-img-inner w-full rounded-t-[20px] flex items-center justify-center" style={`height: clamp(160px, 18.85vw, 340px); background: ${ph.color};`}>
                      <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="color: var(--green); opacity: 0.4;" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                    </div>
                    <div class="flex flex-col items-center flex-1 px-5 pt-4 pb-10 gap-4 text-center">
                      <h3 class="font-lato font-bold text-gray-400 text-[16px]">Loading...</h3>
                    </div>
                  </article>
                </div>
              ))
            )}
          </div>
        </div>
        <button aria-label="Previous products" id="products-prev" class="slick-arrow absolute -left-5 lg:-left-14 top-1/3 items-center justify-center" style="display:none;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button aria-label="Next products" id="products-next" class="slick-arrow absolute -right-5 lg:-right-14 top-1/3 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ===== ABOUT / STATS ===== -->
<section class="relative flow-root pb-20 lg:pb-24" aria-label="About Sosun Fihaara">
  <!-- Background panel -->
  <div class="absolute inset-x-0 top-0 overflow-hidden" style="height: clamp(440px, 75vw, 700px);">
    <div class="w-full h-full" style="background: linear-gradient(135deg, #1a2e1a 0%, #2d5a27 40%, #1e3a1e 100%);"></div>
    {site.partnerImage && (
      <img src={resolveImage(site.partnerImage)} alt="" class="absolute inset-0 w-full h-full object-cover object-center opacity-40" loading="lazy" aria-hidden="true" onerror="this.style.display='none'" />
    )}
  </div>
  <div class="relative mx-4 sm:mx-8 lg:mx-[14.9vw] rounded-t-[25px] lg:rounded-t-[3.6vw] bg-[#fefdfb] px-6 lg:px-[5.2vw] pt-16 pb-16 lg:pt-20 lg:pb-20" style="margin-top: clamp(240px, 35vw, 360px);">
    <div class="fade-up text-center mb-12 lg:mb-12">
      <p class="tagline-text mb-2">Who We Are</p>
      <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-4">
        {site.aboutHeading ? site.aboutHeading : (<>BUILT ON <span class="font-alumni">TRUST</span></>)}
      </h2>
      <p class="sub-title text-[18px] lg:text-[24px] font-light leading-[1.4] max-w-2xl mx-auto">{site.aboutSubtext || 'Sosun Fihaara has been the backbone of FMCG distribution in the Maldives since 1980 — supplying retailers, cafés and households across every atoll with trusted international brands.'}</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5 justify-center mb-12">
      {[
        { num: "40+", label: "Years of Distribution" },
        { num: "25+", label: "International Brands" },
        { num: "300+", label: "Products in Range" },
        { num: "20", label: "Atolls Served" },
      ].map((s) => (
        <div class="text-center border-b-2 pb-4" style="border-color: var(--gold-accent);">
          <p class="font-alumni leading-none tracking-tight" style="color: var(--green-house); font-size: clamp(36px, 4vw, 56px);">{s.num}</p>
          <p class="font-lato text-[11px] sm:text-[13px] font-semibold uppercase tracking-[2px] mt-2" style="color: var(--gold-accent);">{s.label}</p>
        </div>
      ))}
    </div>
    <div class="text-center">
      <a href="/about" class="btn-explore">Our Story</a>
    </div>
  </div>
  <!-- Green marquee ticker -->
  <div class="overflow-hidden py-4 mt-0" style="background: var(--green);" aria-hidden="true">
    <div class="marquee-track flex gap-[10px] whitespace-nowrap">
      <span class="font-alumni text-white text-[24px] tracking-wider">
        {Array(6).fill("WHOLESALE · RETAIL · FMCG · MALDIVES · TRUSTED BRANDS · ISLAND DISTRIBUTION · QUALITY PRODUCTS · ").join("")}
      </span>
    </div>
  </div>
</section>

<!-- ===== BRANDS ===== -->
<section id="brands" class="overflow-hidden pb-20 lg:pb-24" aria-label="Our brand partners">
  <div class="px-5 sm:px-8 lg:px-[9.9vw]">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between pb-8 lg:pb-12 gap-6">
      <div class="fade-left">
        <p class="tagline-text mb-1">Our Trusted Brands</p>
        <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">GLOBAL DISTRIBUTION <span class="font-alumni">BRANDS</span></h2>
        <h3 class="sub-title text-[24px] lg:text-[38px] font-light leading-[1.05] tracking-[-0.84px]">Enabling Seamless Market Access</h3>
      </div>
      <div class="fade-right">
        <a href="/brands" class="btn-explore">Explore Brands</a>
      </div>
    </div>
    <div class="fade-up relative">
      <div class="overflow-hidden">
        <div class="flex ease-in-out" id="brands-track" style="gap: 8px; transition: transform 0.5s ease;">
          {activeBrands.length > 0 ? activeBrands.map((b: any) => (
            <a href={`/brands/${b.slug}`} class="brand-card relative flex-shrink-0 rounded-[16px] border border-[#d3d3d3] bg-white overflow-hidden cursor-pointer no-underline" style="width: calc(20% - 6.4px);" aria-label={`Explore ${b.name}`}>
              <div class="flex items-center justify-center p-4 lg:p-[0.94vw]" style="height: clamp(90px, 9vw, 160px);">
                {b.logo ? (
                  <img src={resolveImage(b.logo)} alt={`${b.name} logo`} class="w-full object-contain" style="max-height: clamp(56px, 5.99vw, 110px);" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                ) : null}
                <div class={`w-full items-center justify-center font-alumni text-center text-[18px] font-bold${b.logo ? ' hidden' : ' flex'}`} style="color: var(--gold-accent);">{b.name}</div>
              </div>
              <div class="brand-detail rounded-[16px]">
                <p class="font-lato font-bold text-sm uppercase tracking-wide mb-3" style="color: var(--green-house);">{b.name}</p>
                <span class="btn-underline text-xs">Explore More</span>
              </div>
            </a>
          )) : (
            ['Brand A','Brand B','Brand C','Brand D','Brand E'].map((name) => (
              <div class="brand-card relative flex-shrink-0 rounded-[16px] border border-[#d3d3d3] bg-white overflow-hidden" style="width: calc(20% - 6.4px);">
                <div class="flex items-center justify-center p-4" style="height: 120px;">
                  <span class="font-alumni text-[18px] font-bold" style="color: var(--gold-accent);">{name}</span>
                </div>
              </div>
            ))
          )}
        </div>
      </div>
      <button aria-label="Previous brands" id="brands-prev" class="slick-arrow absolute -left-4 lg:-left-12 top-1/2 -translate-y-1/2 items-center justify-center" style="display:none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button aria-label="Next brands" id="brands-next" class="slick-arrow absolute -right-4 lg:-right-12 top-1/2 -translate-y-1/2 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- ===== RECIPES ===== -->
<section id="recipes" class="mb-16 lg:mb-24" aria-label="Recipes">
  <div class="flex flex-col lg:flex-row px-5 sm:px-8 lg:px-[9.9vw] gap-12 lg:gap-0">
    <div class="lg:w-[38%] lg:pr-[5.2vw]">
      <div class="fade-left mb-8 lg:mb-10">
        <p class="tagline-text mb-1">Recipes Made Simple</p>
        <h2 class="main-title text-[42px] sm:text-[56px] lg:text-[88px] leading-[.9] tracking-[-2px] mb-2">RECIPES <span class="font-alumni">FOR FOOD</span></h2>
        <h3 class="sub-title text-[24px] lg:text-[38px] font-light leading-[1.05] tracking-[-0.84px]">Lovers Like You</h3>
      </div>
      <div class="fade-left">
        <p class="font-lato text-[15px] lg:text-[18px] font-light text-[#0d2c22] leading-[1.65] mb-6">Discover delicious recipes using the authentic brands we distribute — from quick weeknight meals to weekend feasts.</p>
        <a href="/recipes" class="btn-explore">View All Recipes</a>
      </div>
    </div>
    <div class="lg:w-[62%] flex flex-col gap-5">
      {[
        { tag: "FEATURED", title: "Real Thai Pad Thai", sub: "Ready in 20 minutes", bg: "linear-gradient(135deg, #2d5a27, #4a7c3a)", h: "300px" },
        { tag: "QUICK MEAL", title: "Gullon Biscuit Tart", sub: "A crowd-pleasing dessert", bg: "linear-gradient(135deg, #5a3a20, #8c5a30)", h: "200px" },
      ].map((r) => (
        <a href="/recipes" class="relative rounded-[20px] overflow-hidden group block no-underline" style={`height: ${r.h};`}>
          <div class="absolute inset-0" style={`background: ${r.bg};`}></div>
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
          <div class="absolute bottom-5 left-6">
            <span class="recipe-featured-tag px-2 py-1 text-[11px] tracking-[3px] mb-2 inline-block">{r.tag}</span>
            <h3 class="font-alumni text-white text-[28px] leading-tight">{r.title}</h3>
            <p class="font-lato text-white/80 text-sm">{r.sub}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ===== INSTAGRAM ===== -->
<section class="px-5 sm:px-8 lg:px-[8.3vw] pb-16 lg:pb-24" aria-label="Follow us on Instagram">
  <div class="fade-up flex items-center justify-center gap-3 mb-6 lg:mb-8">
    <div class="w-11 h-11 rounded-full overflow-hidden border-2 flex items-center justify-center flex-shrink-0" style="border-color: var(--gold-accent); background: var(--gold-accent);">
      <span class="font-alumni text-white font-bold text-lg">SF</span>
    </div>
    <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" class="font-alumni text-[24px] font-semibold tracking-wide no-underline transition-colors nav-insta" style="color: var(--green-house);">@sosun.fihaara</a>
  </div>
  <div class="fade-up grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
    {[
      { bg: "linear-gradient(135deg, #2d5a27, #4a8c40)", label: "Post 1" },
      { bg: "linear-gradient(135deg, #5a3a20, #8c5a30)", label: "Post 2" },
      { bg: "linear-gradient(135deg, #1e3a5a, #2a5a8c)", label: "Post 3" },
      { bg: "linear-gradient(135deg, #4a2d5a, #7a4a8c)", label: "Post 4" },
      { bg: "linear-gradient(135deg, #5a5a20, #8c8c30)", label: "Post 5" },
      { bg: "linear-gradient(135deg, #2d3a5a, #3a5a8c)", label: "Post 6" },
    ].map((post, i) => (
      <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" class="relative overflow-hidden rounded-[7px] group block no-underline" style="aspect-ratio: 1;" aria-label={`Instagram post ${i + 1}`}>
        <div class="absolute inset-0 group-hover:scale-110 transition-transform duration-500" style={`background: ${post.bg};`}></div>
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" opacity="0.4"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="white" stroke="none"/></svg>
        </div>
      </a>
    ))}
  </div>
  <div class="text-center">
    <a href="https://www.instagram.com/sosun.fihaara/" target="_blank" rel="noopener noreferrer" class="btn-explore">Follow on Instagram</a>
  </div>
</section>

</div><!-- /main-content -->

<!-- ===== FOOTER ===== -->
<Footer />

<!-- ===== SCRIPTS ===== -->
<script>
  // Scroll-reveal
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.fade-up, .fade-left, .fade-right').forEach(el => io.observe(el));



  // Generic slider helper
  function initSlider(trackId: string, prevId: string, nextId: string, cols: number) {
    const track = document.getElementById(trackId) as HTMLElement | null;
    const prev = document.getElementById(prevId) as HTMLElement | null;
    const next = document.getElementById(nextId) as HTMLElement | null;
    if (!track) return;
    const total = track.children.length;
    let cur = 0;
    function render() {
      const w = (track!.parentElement?.offsetWidth ?? 0);
      const itemW = w / cols;
      track!.style.transform = `translateX(${-cur * (itemW + 8)}px)`;
      if (prev) prev.style.display = cur > 0 ? 'flex' : 'none';
      if (next) next.style.display = cur < total - cols ? 'flex' : 'none';
    }
    prev?.addEventListener('click', () => { cur = Math.max(0, cur - 1); render(); });
    next?.addEventListener('click', () => { cur = Math.min(total - cols, cur + 1); render(); });
    render();
    window.addEventListener('resize', render, { passive: true });
  }

  initSlider('products-track', 'products-prev', 'products-next', window.innerWidth < 640 ? 1 : window.innerWidth < 1024 ? 2 : 3);
  initSlider('brands-track', 'brands-prev', 'brands-next', window.innerWidth < 640 ? 2 : window.innerWidth < 1024 ? 3 : 5);
</script>

</HomeLayout>
