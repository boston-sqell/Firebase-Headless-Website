---
// contact.astro - Reframe contact page to simple general inquiry
import Layout from '../layouts/Layout.astro';
import { getCmsData } from '../lib/cms';

const { site } = await getCmsData();
const isSuccess = Astro.url.searchParams.get('success') === 'true';
---

<Layout
  title="Contact Us | Sosun Fihaara"
  description="Contact Sosun Fihaara in Malé, Maldives. Reach our general trade support or send a general enquiry. Phone +960 331 3020, email info@sosunfihaara.com."
>
  <main class="bg-[#F6F2E8] py-20 min-h-screen pt-28">
    <div class="max-w-[1320px] mx-auto px-5 lg:px-10">
      <div class="text-center mb-12">
        <span class="text-xs uppercase tracking-wider text-[#C5A578] font-bold font-body">Get In Touch</span>
        <h1 class="font-display font-bold text-[#18231D] mt-2 mb-3" style="font-size: var(--type-h2);">Contact Us</h1>
        <p class="font-body text-[#566159] text-sm max-w-lg mx-auto">
          Have a general question about our services or retail outlets? Fill in the form or call us directly. For wholesale and B2B quote requests, please use our <a href="/request-quote" class="text-[#00663B] font-bold hover:underline">Wholesale Quote Form</a>.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Col 1: Contact Details -->
        <div class="flex flex-col gap-8">
          <div class="bg-white border border-[#D8D4C9] rounded-2xl p-8 shadow-sm">
            <h2 class="font-display font-bold text-xl text-[#18231D] mb-6">Our Contact Details</h2>
            
            <div class="flex flex-col gap-6">
              <div class="flex gap-4">
                <span class="w-10 h-10 rounded-lg bg-[#DDEBE2] flex items-center justify-center text-[#00663B] shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </span>
                <div>
                  <h4 class="font-display font-bold text-sm text-[#18231D]">Address</h4>
                  <p class="font-body text-[#566159] text-sm mt-1 leading-relaxed">
                    {site.contactAddress || 'Sosun Fihaara, Moosa Ibrahim Didi Goalhi, Malé, Maldives'}
                  </p>
                </div>
              </div>

              <div class="flex gap-4">
                <span class="w-10 h-10 rounded-lg bg-[#DDEBE2] flex items-center justify-center text-[#00663B] shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </span>
                <div>
                  <h4 class="font-display font-bold text-sm text-[#18231D]">Phone Link</h4>
                  <a href={`tel:${site.contactPhone || '+9603313020'}`} class="font-body text-[#00663B] text-sm font-bold mt-1 block hover:underline">
                    {site.contactPhone || '+960 331 3020'}
                  </a>
                </div>
              </div>

              <div class="flex gap-4">
                <span class="w-10 h-10 rounded-lg bg-[#DDEBE2] flex items-center justify-center text-[#00663B] shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </span>
                <div>
                  <h4 class="font-display font-bold text-sm text-[#18231D]">Email Address</h4>
                  <a href={`mailto:${site.contactEmail || 'info@sosunfihaara.com'}`} class="font-body text-[#00663B] text-sm font-bold mt-1 block hover:underline">
                    {site.contactEmail || 'info@sosunfihaara.com'}
                  </a>
                </div>
              </div>

              <div class="flex gap-4">
                <span class="w-10 h-10 rounded-lg bg-[#DDEBE2] flex items-center justify-center text-[#00663B] shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </span>
                <div>
                  <h4 class="font-display font-bold text-sm text-[#18231D]">Operating Hours</h4>
                  <p class="font-body text-[#566159] text-sm mt-1 leading-relaxed">
                    Monday – Saturday · 9:00 AM – 6:00 PM
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-[#083C2B] text-white rounded-2xl p-8 shadow-sm">
            <h3 class="font-display font-bold text-lg text-white mb-2">Need a tailored B2B quote?</h3>
            <p class="font-body text-sm text-[#DDEBE2]/85 leading-relaxed mb-6">
              If you represent an island merchant, resort kitchen, or international brand principal, please use our B2B procurement form.
            </p>
            <a href="/request-quote" class="btn-secondary-white">
              Request a B2B Quote
            </a>
          </div>
        </div>

        <!-- Col 2: General Enquiry Form -->
        <div class="bg-white border border-[#D8D4C9] rounded-2xl p-8 shadow-sm">
          {isSuccess ? (
            <div class="text-center py-10 font-body">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mx-auto mb-6"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <h2 class="font-display font-bold text-2xl text-[#18231D] mb-2">Thank You</h2>
              <p class="text-[#566159] text-sm max-w-sm mx-auto mb-6">
                Your message has been received. Our team will get back to you shortly.
              </p>
              <a href="/contact" class="btn-primary-inline">Send another message</a>
            </div>
          ) : (
            <>
              <h2 class="font-display font-bold text-xl text-[#18231D] mb-2">Send a Message</h2>
              <p class="font-body text-xs text-[#566159] mb-6">Fill in the details below and we will respond within one business day.</p>
              
              <form class="flex flex-col gap-5" action="/api/contact" method="post">
                <!-- Honeypot -->
                <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
                  <label for="website">Leave this field empty</label>
                  <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
                </div>

                <input type="hidden" name="form_type" value="contact" />

                <div class="flex flex-col gap-2">
                  <label for="name" class="text-sm font-bold text-[#18231D] font-body">Full Name <span class="text-[#A12B2B]">*</span></label>
                  <input type="text" id="name" name="name" required placeholder="Your name" autocomplete="name" class="form-input" />
                </div>

                <div class="flex flex-col gap-2">
                  <label for="company" class="text-sm font-bold text-[#18231D] font-body">Company / Shop Name</label>
                  <input type="text" id="company" name="company" placeholder="Business name (optional)" autocomplete="organization" class="form-input" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="flex flex-col gap-2">
                    <label for="email" class="text-sm font-bold text-[#18231D] font-body">Email Address <span class="text-[#A12B2B]">*</span></label>
                    <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email" class="form-input" />
                  </div>
                  <div class="flex flex-col gap-2">
                    <label for="phone" class="text-sm font-bold text-[#18231D] font-body">Phone Number <span class="text-[#A12B2B]">*</span></label>
                    <input type="tel" id="phone" name="phone" required placeholder="+960 000-0000" autocomplete="tel" class="form-input" />
                  </div>
                </div>

                <div class="flex flex-col gap-2">
                  <label for="message" class="text-sm font-bold text-[#18231D] font-body">Message <span class="text-[#A12B2B]">*</span></label>
                  <textarea id="message" name="message" required placeholder="Type your message here..." class="form-input min-h-[140px]"></textarea>
                </div>

                <button type="submit" class="btn-submit">
                  Send Message
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
                </button>
              </form>
            </>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .form-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid var(--color-line);
    background-color: #FFFFFF;
    color: var(--color-ink);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .form-input:focus {
    border-color: var(--color-green);
    box-shadow: 0 0 0 3px var(--color-green-soft);
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: var(--color-green);
    color: var(--color-surface) !important;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    height: 48px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    transition: background-color 0.16s ease, transform 0.16s ease;
  }
  .btn-submit:hover {
    background-color: var(--color-green-dark);
    transform: translateY(-2px);
  }

  .btn-primary-inline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-green);
    color: var(--color-surface) !important;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    height: 44px;
    padding: 0 20px;
    border-radius: 10px;
    text-decoration: none;
    transition: background-color 0.16s ease;
  }
  .btn-primary-inline:hover {
    background-color: var(--color-green-dark);
  }

  .btn-secondary-white {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    color: var(--color-surface) !important;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    height: 44px;
    padding: 0 20px;
    border-radius: 10px;
    border: 1px solid var(--color-sand);
    transition: background-color 0.16s ease, color 0.16s ease;
    text-decoration: none;
  }
  .btn-secondary-white:hover {
    background-color: var(--color-sand);
    color: var(--color-green-dark) !important;
  }
</style>
