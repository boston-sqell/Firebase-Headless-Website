---
import Layout from '../layouts/Layout.astro';
const isSuccess = Astro.url.searchParams.get('success') === 'true';
---

<Layout
  title="CONTACT | Sosun Fihaara"
  description="Contact Sosun Fihaara in Malé, Maldives — request a quote, become a stockist, or reach our trade team. Phone +960 331 3020, email info@sosunfihaara.com."
>
<main>

<section class="page-hero">
  <div class="container page-hero__inner">
    <h1>Contact Us</h1>
    <p class="crumbs"><a href="/">Home</a> &nbsp;/&nbsp; <span>Contact Us</span></p>
  </div>
</section>

<!-- CONTACT GRID -->
<section class="section bg-cream">
  <div class="container">
    <div class="split" style="align-items:start;gap:clamp(32px,5vw,72px)">
      <!-- info -->
      <div>
        <span class="kicker">Talk to us</span>
        <h2 style="margin:10px 0 16px">Dedicated to your business</h2>
        <p style="color:var(--muted);margin-bottom:32px">Have a question, need a quote, or want to become a stockist? Our trade team is ready to help — reach out and we'll get back to you fast.</p>
        <div class="contact-list">
          <div class="contact-item">
            <span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span>
            <div><h4>Address</h4><p>Sosun Fihaara, Moosa Ibrahim Didi Goalhi, Malé, Maldives</p></div>
          </div>
          <div class="contact-item">
            <span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.7 2.6a2 2 0 0 1-.5 2.1L8.1 9.6a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.8.3 1.7.6 2.6.7a2 2 0 0 1 1.7 2z"></path></svg></span>
            <div><h4>Phone</h4><a href="tel:+9603313020">+960 331 3020</a></div>
          </div>
          <div class="contact-item">
            <span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="M22 6l-10 7L2 6"></path></svg></span>
            <div><h4>Email</h4><a href="mailto:info@sosunfihaara.com">info@sosunfihaara.com</a></div>
          </div>
          <div class="contact-item">
            <span class="ci-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg></span>
            <div><h4>Opening hours</h4><p>Monday – Saturday · 9:00 AM – 6:00 PM</p></div>
          </div>
        </div>
        <div class="socials" style="margin-top:8px">
          <a href="https://www.facebook.com/sosunfihaara" aria-label="Facebook" style="border-color:var(--line);color:var(--green)"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v7h3v-7h2.5l.5-3H14V9z"></path></svg></a>
          <a href="https://www.instagram.com/sosun.fihaara" aria-label="Instagram" style="border-color:var(--line);color:var(--green)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"></rect><circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle></svg></a>
        </div>
      </div>

      <!-- form -->
      <div class="card" style="padding:clamp(24px,3vw,40px)">
        {isSuccess ? (
          <div style="text-align: center; padding: 40px 0;">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; margin-bottom: 16px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <h3 style="font-size:24px;margin-bottom:6px">Thank you!</h3>
            <p style="color:var(--muted);font-size:15.5px">Your enquiry has been received. Our team will get back to you shortly.</p>
            <a href="/contact" class="btn btn--outline mt-4">Send another message</a>
          </div>
        ) : (
          <>
            <h3 style="font-size:24px;margin-bottom:6px">Request a quote</h3>
            <p style="color:var(--muted);margin-bottom:24px;font-size:15.5px">Fill in the details below and our team will respond within one business day.</p>
            <form class="form" action="/api/contact" method="post" novalidate="">
          <!-- Honeypot: hidden from real users via CSS, bots that auto-fill every field will trip it -->
          <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
            <label for="website">Leave this field empty</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
          </div>
          <div class="form__row">
            <div class="field">
              <label for="name">Full name <span class="req" aria-hidden="true">*</span></label>
              <input type="text" id="name" name="name" placeholder="Your name" required="" autocomplete="name">
            </div>
            <div class="field">
              <label for="company">Business name</label>
              <input type="text" id="company" name="company" placeholder="Shop or company" autocomplete="organization">
            </div>
          </div>
          <div class="form__row">
            <div class="field">
              <label for="email">Email <span class="req" aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required="" autocomplete="email">
            </div>
            <div class="field">
              <label for="phone">Phone <span class="req" aria-hidden="true">*</span></label>
              <input type="tel" id="phone" name="phone" placeholder="+960 000 0000" required="" autocomplete="tel">
            </div>
          </div>
          <div class="field">
            <label for="type">Enquiry type</label>
            <select id="type" name="type">
              <option value="wholesale">Wholesale / Stockist enquiry</option>
              <option value="retail">Retail / Product enquiry</option>
              <option value="brand">Brand partnership</option>
              <option value="other">Something else</option>
            </select>
          </div>
          <div class="field">
            <label for="message">How can we help? <span class="req" aria-hidden="true">*</span></label>
            <textarea id="message" name="message" placeholder="Tell us the products, volumes or questions you have…" required=""></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--lg">
            Send Enquiry
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
          </button>
        </form>
        </>
        )}
      </div>
    </div>
  </div>
</section>

<!-- FAQ ACCORDION (unique) -->
<section class="section bg-white">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Good to know</span>
      <h2>Frequently asked <span class="accent">questions</span></h2>
    </div>
    <div class="faq" style="margin-inline:auto">
      <details open="">
        <summary>Do you supply both wholesale and retail customers? <span class="ic" aria-hidden="true"></span></summary>
        <div class="faq__body">Yes. We serve retailers, cafés and institutions at wholesale volumes with trade pricing, and we also make our products available to end customers. Whatever your scale, we can supply you.</div>
      </details>
      <details>
        <summary>Which islands do you deliver to? <span class="ic" aria-hidden="true"></span></summary>
        <div class="faq__body">We distribute across the Maldives — from Malé to the outer atolls — supported by a network of authorised sub-distributors in regions such as Addu City and Laamu for faster local supply.</div>
      </details>
      <details>
        <summary>How do I become a stockist? <span class="ic" aria-hidden="true"></span></summary>
        <div class="faq__body">Simply submit the quote form above or call our trade team. We'll discuss your product needs, order volumes and delivery schedule, then set you up with a tailored wholesale account.</div>
      </details>
      <details>
        <summary>How do you handle chilled and dairy products? <span class="ic" aria-hidden="true"></span></summary>
        <div class="faq__body">Temperature-sensitive lines move through a managed cold chain — from storage to delivery — so dairy, puddings and chilled goods reach your shelves in perfect condition.</div>
      </details>
      <details>
        <summary>Is there a minimum order quantity for wholesale? <span class="ic" aria-hidden="true"></span></summary>
        <div class="faq__body">Minimums vary by product line and account type. Tell us your expected volumes on the quote form and our trade team will confirm the best terms for your business.</div>
      </details>
    </div>
  </div>
</section>

</main>
</Layout>
