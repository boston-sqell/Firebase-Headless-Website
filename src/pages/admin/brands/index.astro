---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { adminListBrands } from '../../../lib/admin-data';

const brands = await adminListBrands();
const success = Astro.url.searchParams.get('success');
---

<AdminLayout title="Brands" active="brands">
  {success && <div class="admin-alert admin-alert--success">{success}</div>}

  <div class="admin-toolbar">
    <div></div>
    <a href="/admin/brands/new" class="btn-admin">+ New Brand</a>
  </div>

  <div class="admin-card" style="padding:0">
    {brands.length === 0 ? (
      <p class="empty-state">No brands found.</p>
    ) : (
      <table class="admin-table">
        <thead><tr><th></th><th>Name</th><th>Slug</th><th>Status</th><th></th></tr></thead>
        <tbody>
          {brands.map(b => (
            <tr>
              <td>{b.logo ? <img class="thumb" src={b.logo} alt="" /> : <div class="thumb" />}</td>
              <td>{b.name}</td>
              <td>/brands/{b.slug}</td>
              <td>{b.active !== false ? <span class="pill pill--active">Active</span> : <span class="pill pill--inactive">Hidden</span>}</td>
              <td style="white-space:nowrap">
                <a href={`/admin/brands/${b.id}`} class="btn-admin btn-admin--ghost btn-admin--sm">Edit</a>
                <form method="post" action={`/api/admin/brands/${b.id}/delete`} style="display:inline" onsubmit="return confirm('Delete this brand? Products referencing it will remain but show no brand match.')">
                <input type="hidden" name="csrf_token" value={Astro.locals.csrfToken} />
                  <button type="submit" class="btn-admin btn-admin--danger btn-admin--sm">Delete</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
