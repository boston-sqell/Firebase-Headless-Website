---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { adminListNews } from '../../../lib/admin-data';

const newsItems = await adminListNews();
const success = Astro.url.searchParams.get('success');
---

<AdminLayout title="News" active="news">
  {success && <div class="admin-alert admin-alert--success">{success}</div>}

  <div class="admin-toolbar">
    <div style="flex:1"></div>
    <a href="/admin/news/new" class="btn-admin">+ New News Item</a>
  </div>

  <div class="admin-card" style="padding:0">
    {newsItems.length === 0 ? (
      <p class="empty-state">No news items found.</p>
    ) : (
      <table class="admin-table">
        <thead>
          <tr><th>Title</th><th>Publish Date</th><th>Category</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
          {newsItems.map((n: any) => (
            <tr>
              <td>{n.emoji} {n.title}</td>
              <td>{n.publishedAt}</td>
              <td>{n.eyebrow}</td>
              <td>{n.active !== false ? <span class="pill pill--active">Active</span> : <span class="pill pill--inactive">Hidden</span>}</td>
              <td style="white-space:nowrap; text-align:right">
                <a href={`/admin/news/${n.id}`} class="btn-admin btn-admin--ghost btn-admin--sm">Edit</a>
                <form method="post" action={`/api/admin/news/${n.id}/delete`} style="display:inline" onsubmit="return confirm('Delete this news item?')">
                  <input type="hidden" name="csrf_token" value={Astro.locals.csrfToken} />
                  <button type="submit" class="btn-admin btn-admin--danger btn-admin--sm">Delete</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
