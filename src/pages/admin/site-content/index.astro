---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { adminGetSiteContent } from '../../../lib/admin-data';
import { resolveImage } from '../../../lib/cms';
import ImageUpload from '../../../components/admin/ImageUpload.astro';

const site = await adminGetSiteContent();
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="Site Content" active="site-content">
  {success && <div class="admin-alert admin-alert--success">{success}</div>}
  {error && <div class="admin-alert admin-alert--error">{error}</div>}

  <form method="post" action="/api/admin/site-content/update" enctype="multipart/form-data" class="admin-form">
    <input type="hidden" name="csrf_token" value={Astro.locals.csrfToken} />
    <div class="admin-card">
      <h2>Homepage Hero</h2>
      <ImageUpload id="homeHeroImage" name="homeHeroImage" label="Hero background image" currentImage={site.homeHeroImage ? resolveImage(site.homeHeroImage) : undefined} />
      <div class="field">
        <label for="heroTagline">Tagline (small text above the headline)</label>
        <input type="text" id="heroTagline" name="heroTagline" value={site.heroTagline} placeholder="Est. 1980 - Maldives FMCG" />
      </div>
      <div class="field">
        <label for="heroSubtext">Hero paragraph</label>
        <textarea id="heroSubtext" name="heroSubtext" class="rich-text" placeholder="Four decades of trusted FMCG wholesale and retail distribution...">{site.heroSubtext}</textarea>
      </div>
    </div>

    <div class="admin-card">
      <h2>"Built on Trust" Section</h2>
      <div class="field">
        <label for="aboutHeading">Heading</label>
        <input type="text" id="aboutHeading" name="aboutHeading" value={site.aboutHeading} placeholder="BUILT ON TRUST" />
      </div>
      <div class="field">
        <label for="aboutSubtext">Paragraph</label>
        <textarea id="aboutSubtext" name="aboutSubtext" class="rich-text" placeholder="Sosun Fihaara has been the backbone of FMCG distribution...">{site.aboutSubtext}</textarea>
      </div>
      <ImageUpload id="partnerImage" name="partnerImage" label="Background panel image" currentImage={site.partnerImage ? resolveImage(site.partnerImage) : undefined} />
    </div>

    <div class="admin-card">
      <h2>Brands Page</h2>
      <ImageUpload id="brandsPageHero" name="brandsPageHero" label="Brands page hero image" currentImage={site.brandsPageHero ? resolveImage(site.brandsPageHero) : undefined} />
    </div>

    <div class="admin-card">
      <h2>About Us Page</h2>
      <div class="field">
        <label for="aboutHeroHeading">Hero Heading</label>
        <input type="text" id="aboutHeroHeading" name="aboutHeroHeading" value={site.aboutHeroHeading} placeholder="SOSUN FIHAARA" />
      </div>
      <div class="field">
        <label for="aboutHeroSubtext">Hero Subtext</label>
        <input type="text" id="aboutHeroSubtext" name="aboutHeroSubtext" value={site.aboutHeroSubtext} placeholder="Decades of Growing Maldives" />
      </div>
      <div class="field">
        <label for="aboutHeroDesc">Hero Description</label>
        <textarea id="aboutHeroDesc" name="aboutHeroDesc" class="rich-text" placeholder="From a single store on Majeedhee Magu...">{site.aboutHeroDesc}</textarea>
      </div>
      <div class="field">
        <label for="aboutJourneyQuote">Journey Quote</label>
        <textarea id="aboutJourneyQuote" name="aboutJourneyQuote" class="rich-text" placeholder="Four decades. Four directors. One unwavering commitment...">{site.aboutJourneyQuote}</textarea>
      </div>
      <div class="field">
        <label for="aboutJourneyDesc">Journey Description</label>
        <textarea id="aboutJourneyDesc" name="aboutJourneyDesc" class="rich-text" placeholder="What began as a humble store...">{site.aboutJourneyDesc}</textarea>
      </div>
    </div>

    <div class="admin-card">
      <h2>Global Contact Settings & Form Alerts</h2>
      <div class="field">
        <label for="contactEmail">Public Contact Email</label>
        <input type="email" id="contactEmail" name="contactEmail" value={site.contactEmail} placeholder="sales@sosunfihaara.com" />
      </div>
      <div class="field">
        <label for="contactPhone">Public Phone Number</label>
        <input type="text" id="contactPhone" name="contactPhone" value={site.contactPhone} placeholder="+960 332 2000" />
      </div>
      <div class="field">
        <label for="contactAddress">Public Address</label>
        <input type="text" id="contactAddress" name="contactAddress" value={site.contactAddress} placeholder="Majeedhee Magu, Malé" />
      </div>
      <div class="field">
        <label for="alertEmail">Form Submissions Alert Email</label>
        <input type="email" id="alertEmail" name="alertEmail" value={site.alertEmail} placeholder="alerts@sosunfihaara.com (Requires Firebase Trigger Email Extension)" />
        <p style="font-size:13px; color:var(--text-light); margin-top:4px;">When set, form submissions will be written to the <code>mail</code> collection for the Trigger Email extension to dispatch.</p>
      </div>
    </div>

    <button type="submit" class="btn-admin">Save Changes</button>
  </form>
</AdminLayout>
