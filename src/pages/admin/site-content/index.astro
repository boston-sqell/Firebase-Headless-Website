---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { adminGetSiteContent } from '../../../lib/admin-data';
import { resolveImage } from '../../../lib/cms';

const site = await adminGetSiteContent();
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="Site Content" active="site-content">
  {success && <div class="admin-alert admin-alert--success">{success}</div>}
  {error && <div class="admin-alert admin-alert--error">{error}</div>}

  <form method="post" action="/api/admin/site-content/update" enctype="multipart/form-data" class="admin-form">
    <input type="hidden" name="csrf_token" value={Astro.locals.csrfToken} />
    <div class="admin-card">
      <h2>Homepage Hero</h2>
      <div class="admin-current-image">
        {site.homeHeroImage && <img src={resolveImage(site.homeHeroImage)} alt="" />}
        <div class="field" style="margin:0">
          <label for="homeHeroImage">Hero background image</label>
          <input type="file" id="homeHeroImage" name="homeHeroImage" accept="image/png,image/jpeg,image/webp" />
        </div>
      </div>
      <div class="field">
        <label for="heroTagline">Tagline (small text above the headline)</label>
        <input type="text" id="heroTagline" name="heroTagline" value={site.heroTagline} placeholder="Est. 1980 - Maldives FMCG" />
      </div>
      <div class="field">
        <label for="heroSubtext">Hero paragraph</label>
        <textarea id="heroSubtext" name="heroSubtext" placeholder="Four decades of trusted FMCG wholesale and retail distribution...">{site.heroSubtext}</textarea>
      </div>
    </div>

    <div class="admin-card">
      <h2>"Built on Trust" Section</h2>
      <div class="field">
        <label for="aboutHeading">Heading</label>
        <input type="text" id="aboutHeading" name="aboutHeading" value={site.aboutHeading} placeholder="BUILT ON TRUST" />
      </div>
      <div class="field">
        <label for="aboutSubtext">Paragraph</label>
        <textarea id="aboutSubtext" name="aboutSubtext" placeholder="Sosun Fihaara has been the backbone of FMCG distribution...">{site.aboutSubtext}</textarea>
      </div>
      <div class="admin-current-image">
        {site.partnerImage && <img src={resolveImage(site.partnerImage)} alt="" />}
        <div class="field" style="margin:0">
          <label for="partnerImage">Background panel image</label>
          <input type="file" id="partnerImage" name="partnerImage" accept="image/png,image/jpeg,image/webp" />
        </div>
      </div>
    </div>

    <div class="admin-card">
      <h2>Brands Page</h2>
      <div class="admin-current-image">
        {site.brandsPageHero && <img src={resolveImage(site.brandsPageHero)} alt="" />}
        <div class="field" style="margin:0">
          <label for="brandsPageHero">Brands page hero image</label>
          <input type="file" id="brandsPageHero" name="brandsPageHero" accept="image/png,image/jpeg,image/webp" />
        </div>
      </div>
    </div>

    <button type="submit" class="btn-admin">Save Changes</button>
  </form>
</AdminLayout>
