---
import '../styles/global.css';
import '../styles/homepage.css';
import '../styles/homepage-custom.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import LenisSetup from '../components/LenisSetup.astro';
import { ClientRouter } from 'astro:transitions';
import { DEFAULT_TITLE, DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE, SITE_URL, organizationSchema } from '../lib/seo';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noNav?: boolean;
	noFooter?: boolean;
}

const {
	title = DEFAULT_TITLE,
	description = DEFAULT_DESCRIPTION,
	image = DEFAULT_OG_IMAGE,
	noNav = false,
	noFooter = false,
} = Astro.props;

// og:image must be an absolute URL per the Open Graph spec.
const imageUrl = new URL(image, Astro.site || SITE_URL).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Alumni+Sans+SC:wght@100;200;300;400;500;600;700;800;900&family=Lato:wght@300;400;600;700;900&display=swap" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || "https://sosunfihaara.com").toString()} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={imageUrl} />
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={imageUrl} />
		<script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
		<ClientRouter />
	</head>
	<body>
		<CustomCursor />
		<LenisSetup />
		{!noNav && <Nav />}
		<slot />
		{!noFooter && <Footer />}
	</body>
</html>
