---
import '../styles/admin.css';

interface Props {
  title: string;
  active: 'dashboard' | 'products' | 'brands' | 'categories' | 'site-content' | 'messages';
}

const { title, active } = Astro.props;
const email = Astro.locals.adminEmail || '';

const navItems: Array<{ key: Props['active']; href: string; label: string }> = [
  { key: 'dashboard', href: '/admin', label: 'Dashboard' },
  { key: 'products', href: '/admin/products', label: 'Products' },
  { key: 'brands', href: '/admin/brands', label: 'Brands' },
  { key: 'categories', href: '/admin/categories', label: 'Categories' },
  { key: 'site-content', href: '/admin/site-content', label: 'Site Content' },
  { key: 'messages', href: '/admin/messages', label: 'Messages' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} | Admin | Sosun Fihaara</title>
</head>
<body class="admin-body">
  <div class="admin-shell">
    <aside class="admin-sidebar">
      <div class="admin-sidebar__brand">SOSUN <span>ADMIN</span></div>
      <ul class="admin-nav">
        {navItems.map(item => (
          <li><a href={item.href} class={active === item.key ? 'is-active' : ''}>{item.label}</a></li>
        ))}
      </ul>
      <ul class="admin-nav admin-nav__footer">
        <li><a href="/" target="_blank" rel="noopener">View site</a></li>
        <li><a href="#" id="logoutLink">Log Out</a></li>
      </ul>
    </aside>
    <div class="admin-main">
      <header class="admin-topbar">
        <h1>{title}</h1>
        <span class="admin-topbar__user">{email}</span>
      </header>
      <main class="admin-content">
        <slot />
      </main>
    </div>
  </div>

  <script>
    /**
     * Global POST form interceptor for the admin panel.
     *
     * Every admin form already embeds a `csrf_token` hidden input rendered
     * server-side from Astro.locals.csrfToken. This script intercepts the
     * native form submit, reads that value, and re-submits via fetch() with
     * an `x-csrf-token` header. The server reads the header first (before
     * attempting multipart body parsing), making CSRF verification reliable
     * regardless of the Node.js stream-handling environment.
     *
     * Works for all form types including multipart file uploads: the browser
     * builds the correct FormData / multipart body from the <form>, and fetch()
     * sends it with the right Content-Type boundary automatically.
     */
    document.addEventListener('submit', async (e: SubmitEvent) => {
      const form = e.target as HTMLFormElement | null;
      if (!form || form.method?.toLowerCase() !== 'post') return;
      // Respect onsubmit="return confirm(...)" cancellations on delete forms.
      if (e.defaultPrevented) return;

      e.preventDefault();

      const fd = new FormData(form);
      const csrfToken = (fd.get('csrf_token') as string) || '';

      // Disable the submit button to prevent double-submits.
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const originalText = btn?.textContent || '';
      if (btn) { btn.disabled = true; btn.textContent = 'Saving…'; }

      try {
        const res = await fetch(form.action || window.location.href, {
          method: 'POST',
          headers: { 'x-csrf-token': csrfToken },
          body: fd,
          redirect: 'follow',
        });

        if (res.redirected) {
          window.location.href = res.url;
          return;
        }

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          const msg = data.error || `Server error (${res.status}). Please try again.`;
          // Prepend an error banner inside .admin-content.
          const banner = document.createElement('div');
          banner.className = 'admin-alert admin-alert--error';
          banner.textContent = msg;
          const content = document.querySelector('.admin-content');
          if (content) content.prepend(banner);
          else alert(msg);
          setTimeout(() => banner.remove(), 10000);
          if (btn) { btn.disabled = false; btn.textContent = originalText; }
        }
      } catch (err) {
        console.error('[admin] form submission failed:', err);
        if (btn) { btn.disabled = false; btn.textContent = originalText; }
        alert('Network error. Please check your connection and try again.');
      }
    });

    // Logout handler.
    document.getElementById('logoutLink')?.addEventListener('click', async (e) => {
      e.preventDefault();
      await fetch('/api/admin/session', { method: 'DELETE' }).catch(() => {});
      window.location.href = '/admin/login';
    });
  </script>
</body>
</html>
