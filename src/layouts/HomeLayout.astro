---
import '../styles/homepage.css';

import '../styles/homepage-custom.css';

import { DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE, SITE_URL, organizationSchema } from '../lib/seo';
import CustomCursor from '../components/CustomCursor.astro';
import LenisSetup from '../components/LenisSetup.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  preloadImage?: string;
}

const {
  title = "HOME | Sosun Fihaara",
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_OG_IMAGE,
  preloadImage,
} = Astro.props;

// og:image must be an absolute URL per the Open Graph spec.
const imageUrl = new URL(image, Astro.site || SITE_URL).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Alumni+Sans+SC:wght@100;200;300;400;500;600;700;800;900&family=Lato:wght@300;400;600;700;900&display=swap" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || SITE_URL).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
    <ClientRouter />
  </head>
  <body>
    <CustomCursor />
    <LenisSetup />
    <slot />
  </body>
</html>
