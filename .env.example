# Sosun Fihaara -- Firebase Edition -- Required Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control (it's already in .gitignore).
#
# This mirrors .env.local.example, which is the source of truth. See that
# file's comments for where to find each value in the Firebase Console.

# -- Firebase Admin (server-side only -- never sent to the browser) ---------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# -- Firebase client config (admin login page only -- not secret) -----------
PUBLIC_FIREBASE_API_KEY=your-web-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# -- Site domain (REQUIRED before go-live) ------------------------------------
# Used for CORS/CSRF origin checks. Include https://, no trailing slash, no www.
PUBLIC_SITE_URL=https://sosunfihaara.com

# -- Optional ------------------------------------------------------------------
# FIREBASE_PREVIEW_URL=https://sosun-fihaara--preview-xxxx.web.app

# -- Wix (one-time migration scripts only -- not used by the live site) -----
# WIX_CLIENT_ID=
# WIX_CLIENT_SECRET=
